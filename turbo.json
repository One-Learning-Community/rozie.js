{
  "$schema": "https://turborepo.dev/schema.json",
  "tasks": {
    "sync": {
      "inputs": ["rozie-sync.manifest.json", "$TURBO_ROOT$/examples/*.rozie"],
      "outputs": ["src/**/*.rozie", "app/**/*.rozie"]
    },
    "build": {
      "dependsOn": ["^build", "sync"],
      "outputs": ["dist/**", "src/**/*.d.rozie.ts", "app/**/*.d.rozie.ts"]
    },
    "@rozie/runtime-svelte#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@rozie-ui/sortable-list#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@rozie-ui/sortable-list-vue#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@rozie-ui/sortable-list-svelte#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "@rozie-ui/sortable-list-angular#build": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "sync"],
      "outputs": []
    },
    "test:visual": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "lint": {
      "dependsOn": []
    },
    "typecheck": {
      "dependsOn": ["^build", "sync"],
      "outputs": []
    },
    "dev": {
      "dependsOn": ["^build", "sync"],
      "cache": false,
      "persistent": true
    }
  }
}
