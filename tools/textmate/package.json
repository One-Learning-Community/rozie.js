{
  "name": "rozie-textmate",
  "displayName": "Rozie",
  "description": "Syntax highlighting for .rozie Single-File Component files",
  "version": "0.2.0",
  "publisher": "onelearningcommunity",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/One-Learning-Community/rozie.js",
    "directory": "tools/textmate"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js/tree/main/tools/textmate#readme",
  "keywords": [
    "rozie",
    "syntax",
    "highlighting",
    "single-file-component",
    "vue",
    "svelte",
    "react",
    "angular"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Programming Languages"],
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.0.0"
  },
  "contributes": {
    "languages": [
      {
        "id": "rozie",
        "aliases": ["Rozie", "rozie"],
        "extensions": [".rozie"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "rozie",
        "scopeName": "source.rozie",
        "path": "./syntaxes/rozie.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.script.rozie": "javascript",
          "meta.embedded.block.script.ts.rozie": "typescript",
          "meta.embedded.block.style.rozie": "css",
          "meta.embedded.block.style.scss.rozie": "scss",
          "meta.embedded.expression.rozie": "javascript"
        }
      }
    ]
  }
}
