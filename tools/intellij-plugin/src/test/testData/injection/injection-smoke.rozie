<rozie name="InjectionSmoke">
<props>{ value: { type: Number, default: 0 } }</props>
<data>{ count: 0 }</data>
<script>
const message = "hello"
$onMount(() => {
  console.log(message)
})
</script>
<listeners>
  <listener :target="window" @resize="$data.count++" r-if="true" />
</listeners>
<components>
{
  Counter: './Counter.rozie',
}
</components>
<template>
  <button @click="$data.count++">Click {{ $data.count }}</button>
  <Modal #[$data.slotName]>Dynamic content</Modal>
</template>
<style>
button { color: red; }
</style>
</rozie>
