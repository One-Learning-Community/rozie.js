<idea-plugin>
    <id>js.rozie</id>
    <name>Rozie.js</name>
    <vendor email="internal@rozie.js">Rozie.js</vendor>

    <description><![CDATA[
        <p><strong>Internal dogfooding build — not for Marketplace distribution.</strong></p>
        <p>Adds <code>.rozie</code> file type recognition with Rozie-aware syntax
        highlighting and JS/HTML/CSS language injection into block bodies.</p>
        <p>Required IDE: IDEA Ultimate / WebStorm / PhpStorm / RubyMine / GoLand /
        PyCharm Pro 2024.2+. Does not work on Community edition (no JS plugin).</p>
    ]]></description>

    <change-notes><![CDATA[
        <p><strong>0.3.0</strong> — Language constructs synced to Rozie grammar
        v0.2.0. New directives recognised in &lt;template&gt;:
        <code>r-match</code> / <code>r-case</code> / <code>r-default</code>
        (Phase 11 switch-style conditionals) — attribute-name completion and
        sigil coloring. New magic identifiers recognised in injected JS:
        <code>$el</code>, <code>$onUnmount</code>, <code>$portals</code>,
        <code>$classSelector</code> — completion, coloring, and synthetic
        ambient declarations. Dropped <code>$listeners</code> and
        <code>$expose</code> from the magic-identifier set: neither is a
        compiler-recognised identifier (<code>$expose</code> is a deferred v2
        feature; <code>&lt;listeners&gt;</code> is a block, not a sigil).</p>
        <p><strong>0.3.0</strong> (editor) — Modifier autocomplete: typing a
        <code>.</code> in an <code>@event</code> / <code>r-on:event</code> /
        <code>r-model</code> attribute now offers the event composition
        modifiers, the key/button filters (on keyboard events), and the three
        <code>r-model</code> modifiers. SFC block folding: <code>&lt;template&gt;</code>,
        <code>&lt;script&gt;</code>, <code>&lt;style&gt;</code> and the other
        blocks collapse to a one-line placeholder. Quick documentation:
        Ctrl-Q / hover on an <code>r-*</code> directive, a modifier, or a
        <code>$</code>-magic identifier now shows inline docs. Inspection:
        a typo'd <code>r-*</code> directive or <code>.modifier</code> is
        flagged with a "did you mean" rename quick-fix. Structure view: a
        <code>.rozie</code> file's SFC blocks appear in the Structure tool
        window for quick navigation. New-file action: "New &gt; Rozie
        Component" scaffolds a <code>.rozie</code> single-file component.
        Inspection: assigning to a non-<code>model</code> prop
        (<code>$props.x = …</code>) is flagged as a ROZ200 error.</p>
        <p><strong>0.2.0</strong> — Architectural pivot to injection-first model.
        HTML coloring inside &lt;template&gt; now matches the TextMate bundle.
        Smart navigation: $props.X / $data.X / $refs.X Go-to-Declaration.
        Color-scheme keys removed (no longer in use): ROZIE_EVENT_AT,
        ROZIE_EVENT_NAME, ROZIE_MODIFIER, ROZIE_MODIFIER_PUNCTUATION,
        ROZIE_PROP_BINDING_PUNCT, ROZIE_PROP_BINDING_NAME, ROZIE_INTERPOLATION_DELIM,
        ROZIE_REF_ATTR, ROZIE_HTML_ATTR_NAME, ROZIE_COMPONENT_REF,
        ROZIE_DIRECTIVE_COLON, ROZIE_DIRECTIVE_ARG, ROZIE_SLOT_FILL_MARKER,
        ROZIE_SLOT_NAME, ROZIE_SLOT_BRACKET. Users who customised these will see
        them revert to default HTML coloring — expected since v0.1.0 was internal
        dogfooding only.</p>
    ]]></change-notes>

    <!-- Required modules. JavaScript + com.intellij.css gate the plugin to
         IDEs that bundle them (IDEA Ultimate, WebStorm, PhpStorm, RubyMine,
         GoLand, PyCharm Pro). Pitfall 1 mitigation. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xml</depends>
    <depends>JavaScript</depends>
    <depends>com.intellij.css</depends>
    <!-- LSP4IJ (Red Hat) — the LSP client used to consume the shared
         @rozie/language-server brain (Option C). Semantic features (ROZ
         diagnostics, and later cross-block nav / member completion / rename)
         are served by @rozie/core over LSP rather than re-implemented here. -->
    <depends>com.redhat.devtools.lsp4ij</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Rozie"
            implementationClass="js.rozie.intellij.RozieFileType"
            fieldName="INSTANCE"
            language="Rozie"
            extensions="rozie"/>

        <lang.parserDefinition
            language="Rozie"
            implementationClass="js.rozie.intellij.parser.RozieParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="Rozie"
            implementationClass="js.rozie.intellij.highlighting.RozieSyntaxHighlighterFactory"/>
        <colorSettingsPage
            implementation="js.rozie.intellij.highlighting.RozieColorSettingsPage"/>

        <!-- 0.3.0: collapse each SFC block (<template> / <script> / <props> /
             <data> / <listeners> / <components> / <style> and the outer
             <rozie> wrapper) to a one-line placeholder — the affordance
             Vue / Svelte SFC editors give. Operates on the flat host token
             stream; injected HTML/JS/CSS folding is unaffected. -->
        <lang.foldingBuilder
            language="Rozie"
            implementationClass="js.rozie.intellij.folding.RozieFoldingBuilder"/>

        <!-- 0.3.0: Structure tool-window view listing the SFC blocks of a
             .rozie file for quick navigation. -->
        <lang.psiStructureViewFactory
            language="Rozie"
            implementationClass="js.rozie.intellij.structure.RozieStructureViewFactory"/>

        <!-- 0.4.0: host-level commenter (Ctrl-/ , Ctrl-Shift-/) for SFC
             structural positions. In-block commenting is handled by the
             injected language's own commenter (JS // , CSS, HTML); this governs
             the XML/HTML-shaped structural level, mirroring Vue SFC behavior. -->
        <lang.commenter
            language="Rozie"
            implementationClass="js.rozie.intellij.editor.RozieCommenter"/>

        <!-- 0.4.0: live-template scaffolding snippets for .rozie files —
             rcomponent (full SFC skeleton), rtemplate / rscript / rprops /
             rdata / rcomponents / rlisteners / rstyle (individual blocks). The
             ROZIE context (gated on RozieContextCheck.isRozieContext) keeps the
             snippet set out of the user's other files. -->
        <liveTemplateContext
            contextId="ROZIE"
            implementation="js.rozie.intellij.editor.RozieTemplateContextType"/>
        <defaultLiveTemplates file="/liveTemplates/Rozie.xml"/>

        <!-- 0.3.0: skeleton for the "New > Rozie Component" action. Content
             lives in resources/fileTemplates/internal/Rozie Component.ft. -->
        <internalFileTemplate name="Rozie Component"/>

        <!-- 0.3.0: Quick-Doc (Ctrl-Q) / hover documentation for Rozie template
             attributes — r-* directives, @event / r-on listeners, :prop
             bindings, #slot fills, ref, and the .modifier chain. Registered
             for HTML because the XmlAttribute PSI lives in the injected
             <template> fragment; RozieContextCheck guards non-Rozie .html
             files. The $-magic-identifier docs ride the JSDoc on
             rozie-globals.d.ts instead. -->
        <lang.documentationProvider
            language="HTML"
            implementationClass="js.rozie.intellij.documentation.RozieAttributeDocumentationProvider"/>

        <multiHostInjector
            implementation="js.rozie.intellij.injection.RozieMultiHostInjector"/>

        <xml.xmlSuppressionProvider
            implementation="js.rozie.intellij.inspection.RozieHtmlInspectionSuppressor"/>

        <!-- Plan 08.2-08: closes P1-UAT-05 (script unused-function) + P1-UAT-04
             JS-side belt-and-suspenders for object-literal-key unused warnings.
             Per-block dispatch + RozieContextCheck.isRozieContext short-circuit
             (Pitfall 2 mitigation) confines suppression to .rozie host files. -->
        <lang.inspectionSuppressor language="JavaScript"
            implementationClass="js.rozie.intellij.inspection.RozieJSInspectionSuppressor"/>

        <!-- Plan 08.2-09: closes P1-UAT-06 (style unused-selector). Same
             template as the Plan 08 JS suppressor — Pitfall 2 guarded
             (RozieContextCheck.isRozieContext) + per-block dispatched
             (STYLE_BODY only) + narrow allow-list (CssUnusedSymbol). SCSS +
             Less mirror entries cover <style lang="scss"> / <style lang="less">
             blocks — RozieMultiHostInjector lines 124-128 already injects per
             lang= attribute. -->
        <lang.inspectionSuppressor language="CSS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>
        <lang.inspectionSuppressor language="SCSS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>
        <lang.inspectionSuppressor language="LESS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>

        <!-- 0.3.0: flag typo'd Rozie template attributes — an unknown r-*
             directive or an unknown .modifier on @event / r-on / r-model.
             Registered for HTML (the XmlAttribute PSI is in the injected
             <template>); RozieContextCheck guards non-Rozie .html files.
             Offers a Levenshtein-based "did you mean" rename quick-fix. -->
        <localInspection
            language="HTML"
            shortName="RozieTemplateAttribute"
            displayName="Unknown Rozie directive or modifier"
            groupName="Rozie"
            enabledByDefault="true"
            level="WARNING"
            implementationClass="js.rozie.intellij.inspection.RozieTemplateAttributeInspection"/>

        <!-- RETIRED (Option C): the `$props.x = …` non-model-prop write check
             (ROZ200) is now produced by @rozie/core and surfaced via the LSP
             server below — single source of truth, no Kotlin re-implementation.
             RozieTemplateAttributeInspection (the directive-typo "did you mean")
             is KEPT: unknown r-* directives are NOT a compiler ROZ diagnostic
             (the compiler passes them through), so it has no LSP equivalent
             yet. Adding directive validation to @rozie/core would let it move
             server-side too. -->

        <xml.attributeDescriptorsProvider
            implementation="js.rozie.intellij.xml.RozieAttributeDescriptorsProvider"/>

        <!-- Plan 08.2-03: a single Kotlin class implements both EPs
             (Angular's AngularJSTagDescriptorsProvider precedent).
             Two FQN-identical registrations are required — the tag-name
             autocomplete EP and the tag-recognition descriptor EP. -->
        <xml.tagNameProvider
            implementation="js.rozie.intellij.xml.RozieComponentTagProvider"/>
        <xml.elementDescriptorProvider
            implementation="js.rozie.intellij.xml.RozieComponentTagProvider"/>

        <!-- Plan 08.2-04: SC-4 distinctive-coloring layer painted ADDITIVELY
             over HTML / JavaScript stock coloring inside injected PSI of
             .rozie files. Both annotators short-circuit on
             RozieContextCheck.isRozieContext to avoid leaking into the user's
             non-Rozie .html / .js files (08.2-RESEARCH Pitfall 2). -->
        <annotator language="HTML"
                   implementationClass="js.rozie.intellij.highlighting.RozieAnnotator"/>
        <annotator language="JavaScript"
                   implementationClass="js.rozie.intellij.highlighting.RozieJsAnnotator"/>

        <!-- Plan 08.2-05: SC-5 cross-block PsiReferenceContributor — wires
             $props.X / $data.X / $refs.X Go-to-Declaration / Find-Usages /
             Rename to declarations in sibling SFC blocks. Registered for
             language="JavaScript" (NOT "Rozie") per 08.2-RESEARCH Pitfall 3:
             the JSReferenceExpressions we match live in INJECTED JS PSI, not
             in host Rozie PSI. Vue's VueJSReferenceContributor uses the same
             pattern. Pitfall 2 mitigation via RozieContextCheck.isRozieContext
             short-circuit; Pitfall 5 mitigation via CachedValuesManager cache
             wrapping inside each reference's multiResolve. -->
        <psi.referenceContributor language="JavaScript"
                                  implementation="js.rozie.intellij.references.RozieJSReferenceContributor"/>

        <!-- Plan 08.3-04: SPEC Req 7 — Find-Usages walks cross-injection PsiReferences.
             The platform's Find-Usages action requires a FindUsagesProvider extension
             in addition to the PsiReference contract (Plan 08.3-01 shipped only the
             PsiReference). Registered for language="JavaScript" because the <script>
             decl targets and their template / directive / handler / colon-bind /
             modifier-arg call sites all live in injected JS PSI — same registration
             scope as the psi.referenceContributor above. Pitfall 2 mitigation lives
             in canFindUsagesFor via RozieContextCheck.isRozieContext. Heavy lifting
             delegates to the JS plugin's stock JavaScriptFindUsagesProvider. -->
        <lang.findUsagesProvider language="JavaScript"
                                 implementationClass="js.rozie.intellij.references.RozieFindUsagesProvider"/>

        <!-- Plan 08.3-04: companion provider for the HOST Rozie-language scan
             pass. The platform picks a WordsScanner per scanned file via
             LanguageFindUsages.INSTANCE.forLanguage(file.language); without a
             provider registered for language="Rozie" the host file is silently
             skipped by the Find-Usages word-index sweep, even with the
             RozieUseScopeEnlarger enlarging scope to include it. The provider's
             only behavior is getWordsScanner -> SimpleWordsScanner (the
             platform's stock identifier-split scanner). canFindUsagesFor
             returns false because Rozie PSI elements are never themselves
             Find-Usages targets — the bare-ident path through Plan 08.3-01 +
             the JS-language RozieFindUsagesProvider above handles that role. -->
        <lang.findUsagesProvider language="Rozie"
                                 implementationClass="js.rozie.intellij.references.RozieHostFindUsagesProvider"/>

        <!-- Plan 08.3-04: SPEC Req 7 — enlarge Find-Usages text-search scope so
             the platform's word-index sweep visits the Rozie host file for
             targets that live inside injected JS (the <script> top-level decls).
             Without this enlarger, a JSFunctionDeclaration's default useScope is
             a LocalSearchScope of the injected JS file alone — the template /
             listener / handler / colon-bind text in sibling SFC blocks is
             outside scope, so Find-Usages returns zero hits even when the
             RozieScriptDeclReference would resolve correctly. Vue's plugin uses
             the same useScopeEnlarger EP for the same reason (VueUseScopeEnlarger).
             Pitfall 2 mitigation lives in getAdditionalUseScope via
             RozieContextCheck.isRozieContext; the enlarger stays inert on every
             non-Rozie .js / .ts / .tsx file (T-08.3-04-01). -->
        <useScopeEnlarger
            implementation="js.rozie.intellij.references.RozieUseScopeEnlarger"/>

        <!-- Plan 08.3-04: SPEC Req 7 — ReferencesSearch bridge. The JS plugin's
             JSReferenceExpression.getReferences() returns ONLY its built-in
             self-reference (verified empirically — see RozieReferenceSearcher
             KDoc); it does NOT include PsiReferenceContributor-contributed refs
             like RozieScriptDeclReference. So the platform's ReferencesSearch
             pipeline never sees our contributed refs when walking candidate
             reference sites. This searcher participates directly in the
             ReferencesSearch pipeline: walks the search scope via
             PsiSearchHelper.processElementsWithWord, asks
             ReferenceProvidersRegistry for contributed refs at each candidate
             offset, and checks each via isReferenceTo(target). Vue's plugin
             uses the same referencesSearch EP for the same reason
             (VueReferenceSearcher). Pitfall 2 mitigation: the searcher's outer
             guard short-circuits on `target not in Rozie SFC`. -->
        <referencesSearch
            implementation="js.rozie.intellij.references.RozieReferenceSearcher"/>

        <!-- Custom rename for <props>/<data> sigil keys. Registered order="first"
             so it wins over the JS plugin's JSDefaultRenameProcessor, which
             cannot rename a key across the multi-injection RozieRootBlock host
             (injected smart-pointer restore failure + missing ElementManipulator
             on the raw TEMPLATE_BODY leaf). This processor edits the host
             document directly, touching neither the injected pointer nor the
             manipulator path. See RozieSigilRenameProcessor. -->
        <renamePsiElementProcessor order="first"
            implementation="js.rozie.intellij.refactoring.RozieSigilRenameProcessor"/>

        <!-- Plan 08.2-06: SC-6 prefix-aware attribute-name autocomplete —
             typing r- / @ / : / # in HTML attribute position inside a .rozie
             <template> surfaces the canonical name lists from
             RozieKnownAttributes (Plan 02 DRY contract). Registered for
             language="HTML" because the XmlAttribute PSI we match lives in
             HTMLLanguage-injected fragments, not host Rozie PSI (Pitfall 3).
             Pitfall 2 mitigation via RozieContextCheck.isRozieContext
             short-circuit so non-Rozie .html files anywhere in the user's
             project stay unaffected. -->
        <completion.contributor language="HTML"
            implementationClass="js.rozie.intellij.completion.RozieAttributeNameCompletionContributor"/>

        <!-- Cross-file component-tag attribute completion: `<Modal :|` / `@|` / `#|`
             offers the producer Modal.rozie's real props / emits / slots (resolved
             via the consumer's <components> import path), additive to stock DOM
             attrs. IntelliJ-native analog of the LSP cross-file surface (LSP4IJ
             completion doesn't reach injected HTML carets). -->
        <completion.contributor language="HTML"
            implementationClass="js.rozie.intellij.completion.RozieComponentAttributeCompletionContributor"/>

        <!-- Plan 08.2-13: closes P1-UAT-09. SC-6 extended to the JS surface —
             typing `$` (or a `$X` prefix) in any Rozie-injected JS fragment
             (<script> / <listeners> / <props> / <data> / <components>)
             surfaces the 13 canonical Rozie magic identifiers ($props /
             $data / $refs / $emit / $computed / $onMount / $onUnmount /
             $onUpdate / $watch / $slots / $el / $portals / $classSelector)
             with one-line type-text doc hints. DRY-sourced from
             RozieMagicIdentifiers; structural mirror of Plan 06's HTML-side
             contributor.
             Registered for language="JavaScript" because the
             JSReferenceExpression PSI we match lives in INJECTED JS PSI,
             not host Rozie PSI (Pitfall 3 — same reasoning Plan 05's
             referenceContributor documents). Pitfall 2 mitigation via
             RozieContextCheck.isRozieContext short-circuit so non-Rozie
             .js / .ts / .tsx files anywhere in the user's project stay
             unaffected. -->
        <!-- Member-access autocomplete for $props.<member> / $data.<member> /
             $refs.<member>, enumerated live from the sibling <props>/<data> JS
             keys and the <template> ref="…" attributes (companion to the
             cross-block RozieJSReferenceContributor navigation). Native because
             LSP4IJ completion does not reach carets inside injected fragments,
             so the IntelliJ LSP is scoped to diagnostics-only — see
             RozieLanguageServerFactory.createClientFeatures. -->
        <completion.contributor language="JavaScript" order="first"
            implementationClass="js.rozie.intellij.completion.RozieMemberCompletionContributor"/>

        <!-- P1-UAT-07: neutralize JetBrains' default INJECTED_LANGUAGE_FRAGMENT
             background tint on .rozie files.  Every SFC block is a language-
             injection target (HTML/JS/CSS), so without these overrides each
             block paints a distracting backdrop.  Vue's plugin uses the same
             additionalTextAttributes pattern.

             One entry per BUNDLED editor color scheme — the override applies
             only to the scheme it names (and schemes deriving from it), NOT
             across all themes. The new UI defaults to "Dark"/"Light" (distinct
             base schemes from classic "Darcula"/"Default"), so those need their
             own entries or the backdrop shows on the default theme. -->
        <additionalTextAttributes scheme="Default" file="colorSchemes/RozieDefault.xml"/>
        <additionalTextAttributes scheme="Darcula" file="colorSchemes/RozieDarcula.xml"/>
        <additionalTextAttributes scheme="Dark" file="colorSchemes/RozieDark.xml"/>
        <additionalTextAttributes scheme="Light" file="colorSchemes/RozieLight.xml"/>
    </extensions>

    <!-- Option C — the shared @rozie/core brain over LSP. The server (a Node
         process running @rozie/language-server) receives the host .rozie file
         and publishes ROZ diagnostics in host coordinates. The factory disables
         the server when its Node script can't be resolved, so this stays inert
         in headless tests and in CI-built plugins that ship without the
         bundle. -->
    <extensions defaultExtensionNs="com.redhat.devtools.lsp4ij">
        <server id="rozie"
                name="Rozie Language Server"
                factoryClass="js.rozie.intellij.lsp.RozieLanguageServerFactory">
            <description><![CDATA[
                Diagnostics (ROZ codes) for <code>.rozie</code> files, served by
                the shared <code>@rozie/core</code> analyzer over LSP.
            ]]></description>
        </server>
        <languageMapping language="Rozie" serverId="rozie"/>
    </extensions>

    <actions>
        <!-- 0.3.0: "New > Rozie Component" entry in the project-view New menu. -->
        <action
            id="js.rozie.NewRozieComponent"
            class="js.rozie.intellij.actions.RozieCreateComponentAction">
            <add-to-group group-id="NewGroup" anchor="first"/>
        </action>
    </actions>
</idea-plugin>
