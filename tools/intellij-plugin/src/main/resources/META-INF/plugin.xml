<idea-plugin>
    <id>js.rozie</id>
    <name>Rozie.js</name>
    <vendor email="internal@rozie.js">Rozie.js</vendor>

    <description><![CDATA[
        <p><strong>Internal dogfooding build — not for Marketplace distribution.</strong></p>
        <p>Adds <code>.rozie</code> file type recognition with Rozie-aware syntax
        highlighting and JS/HTML/CSS language injection into block bodies.</p>
        <p>Required IDE: IDEA Ultimate / WebStorm / PhpStorm / RubyMine / GoLand /
        PyCharm Pro 2024.2+. Does not work on Community edition (no JS plugin).</p>
    ]]></description>

    <change-notes><![CDATA[
        <p><strong>0.2.0</strong> — Architectural pivot to injection-first model.
        HTML coloring inside &lt;template&gt; now matches the TextMate bundle.
        Smart navigation: $props.X / $data.X / $refs.X Go-to-Declaration.
        Color-scheme keys removed (no longer in use): ROZIE_EVENT_AT,
        ROZIE_EVENT_NAME, ROZIE_MODIFIER, ROZIE_MODIFIER_PUNCTUATION,
        ROZIE_PROP_BINDING_PUNCT, ROZIE_PROP_BINDING_NAME, ROZIE_INTERPOLATION_DELIM,
        ROZIE_REF_ATTR, ROZIE_HTML_ATTR_NAME, ROZIE_COMPONENT_REF,
        ROZIE_DIRECTIVE_COLON, ROZIE_DIRECTIVE_ARG, ROZIE_SLOT_FILL_MARKER,
        ROZIE_SLOT_NAME, ROZIE_SLOT_BRACKET. Users who customised these will see
        them revert to default HTML coloring — expected since v0.1.0 was internal
        dogfooding only.</p>
    ]]></change-notes>

    <!-- Required modules. JavaScript + com.intellij.css gate the plugin to
         IDEs that bundle them (IDEA Ultimate, WebStorm, PhpStorm, RubyMine,
         GoLand, PyCharm Pro). Pitfall 1 mitigation. -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.xml</depends>
    <depends>JavaScript</depends>
    <depends>com.intellij.css</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Rozie"
            implementationClass="js.rozie.intellij.RozieFileType"
            fieldName="INSTANCE"
            language="Rozie"
            extensions="rozie"/>

        <lang.parserDefinition
            language="Rozie"
            implementationClass="js.rozie.intellij.parser.RozieParserDefinition"/>

        <lang.syntaxHighlighterFactory
            language="Rozie"
            implementationClass="js.rozie.intellij.highlighting.RozieSyntaxHighlighterFactory"/>
        <colorSettingsPage
            implementation="js.rozie.intellij.highlighting.RozieColorSettingsPage"/>

        <multiHostInjector
            implementation="js.rozie.intellij.injection.RozieMultiHostInjector"/>

        <xml.xmlSuppressionProvider
            implementation="js.rozie.intellij.inspection.RozieHtmlInspectionSuppressor"/>

        <!-- Plan 08.2-08: closes P1-UAT-05 (script unused-function) + P1-UAT-04
             JS-side belt-and-suspenders for object-literal-key unused warnings.
             Per-block dispatch + RozieContextCheck.isRozieContext short-circuit
             (Pitfall 2 mitigation) confines suppression to .rozie host files. -->
        <lang.inspectionSuppressor language="JavaScript"
            implementationClass="js.rozie.intellij.inspection.RozieJSInspectionSuppressor"/>

        <!-- Plan 08.2-09: closes P1-UAT-06 (style unused-selector). Same
             template as the Plan 08 JS suppressor — Pitfall 2 guarded
             (RozieContextCheck.isRozieContext) + per-block dispatched
             (STYLE_BODY only) + narrow allow-list (CssUnusedSymbol). SCSS +
             Less mirror entries cover <style lang="scss"> / <style lang="less">
             blocks — RozieMultiHostInjector lines 124-128 already injects per
             lang= attribute. -->
        <lang.inspectionSuppressor language="CSS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>
        <lang.inspectionSuppressor language="SCSS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>
        <lang.inspectionSuppressor language="LESS"
            implementationClass="js.rozie.intellij.inspection.RozieCssInspectionSuppressor"/>

        <xml.attributeDescriptorsProvider
            implementation="js.rozie.intellij.xml.RozieAttributeDescriptorsProvider"/>

        <!-- Plan 08.2-03: a single Kotlin class implements both EPs
             (Angular's AngularJSTagDescriptorsProvider precedent).
             Two FQN-identical registrations are required — the tag-name
             autocomplete EP and the tag-recognition descriptor EP. -->
        <xml.tagNameProvider
            implementation="js.rozie.intellij.xml.RozieComponentTagProvider"/>
        <xml.elementDescriptorProvider
            implementation="js.rozie.intellij.xml.RozieComponentTagProvider"/>

        <!-- Plan 08.2-04: SC-4 distinctive-coloring layer painted ADDITIVELY
             over HTML / JavaScript stock coloring inside injected PSI of
             .rozie files. Both annotators short-circuit on
             RozieContextCheck.isRozieContext to avoid leaking into the user's
             non-Rozie .html / .js files (08.2-RESEARCH Pitfall 2). -->
        <annotator language="HTML"
                   implementationClass="js.rozie.intellij.highlighting.RozieAnnotator"/>
        <annotator language="JavaScript"
                   implementationClass="js.rozie.intellij.highlighting.RozieJsAnnotator"/>

        <!-- Plan 08.2-05: SC-5 cross-block PsiReferenceContributor — wires
             $props.X / $data.X / $refs.X Go-to-Declaration / Find-Usages /
             Rename to declarations in sibling SFC blocks. Registered for
             language="JavaScript" (NOT "Rozie") per 08.2-RESEARCH Pitfall 3:
             the JSReferenceExpressions we match live in INJECTED JS PSI, not
             in host Rozie PSI. Vue's VueJSReferenceContributor uses the same
             pattern. Pitfall 2 mitigation via RozieContextCheck.isRozieContext
             short-circuit; Pitfall 5 mitigation via CachedValuesManager cache
             wrapping inside each reference's multiResolve. -->
        <psi.referenceContributor language="JavaScript"
                                  implementation="js.rozie.intellij.references.RozieJSReferenceContributor"/>

        <!-- Plan 08.2-06: SC-6 prefix-aware attribute-name autocomplete —
             typing r- / @ / : / # in HTML attribute position inside a .rozie
             <template> surfaces the canonical name lists from
             RozieKnownAttributes (Plan 02 DRY contract). Registered for
             language="HTML" because the XmlAttribute PSI we match lives in
             HTMLLanguage-injected fragments, not host Rozie PSI (Pitfall 3).
             Pitfall 2 mitigation via RozieContextCheck.isRozieContext
             short-circuit so non-Rozie .html files anywhere in the user's
             project stay unaffected. -->
        <completion.contributor language="HTML"
            implementationClass="js.rozie.intellij.completion.RozieAttributeNameCompletionContributor"/>

        <!-- Plan 08.2-13: closes P1-UAT-09. SC-6 extended to the JS surface —
             typing `$` (or a `$X` prefix) in any Rozie-injected JS fragment
             (<script> / <listeners> / <props> / <data> / <components>)
             surfaces the 11 canonical Rozie magic identifiers ($props /
             $data / $refs / $emit / $computed / $onMount / $onUpdate /
             $watch / $listeners / $slots / $expose) with one-line type-text
             doc hints. DRY-sourced from RozieMagicIdentifiers; structural
             mirror of Plan 06's HTML-side contributor.
             Registered for language="JavaScript" because the
             JSReferenceExpression PSI we match lives in INJECTED JS PSI,
             not host Rozie PSI (Pitfall 3 — same reasoning Plan 05's
             referenceContributor documents). Pitfall 2 mitigation via
             RozieContextCheck.isRozieContext short-circuit so non-Rozie
             .js / .ts / .tsx files anywhere in the user's project stay
             unaffected. -->
        <completion.contributor language="JavaScript"
            implementationClass="js.rozie.intellij.completion.RozieJsMagicIdentifierCompletionContributor"/>

        <!-- P1-UAT-07: neutralize JetBrains' default INJECTED_LANGUAGE_FRAGMENT
             background tint on .rozie files.  Every SFC block is a language-
             injection target (HTML/JS/CSS), so without these overrides each
             block paints a distracting backdrop.  Vue's plugin uses the same
             additionalTextAttributes pattern. -->
        <additionalTextAttributes scheme="Default" file="colorSchemes/RozieDefault.xml"/>
        <additionalTextAttributes scheme="Darcula" file="colorSchemes/RozieDarcula.xml"/>
    </extensions>
</idea-plugin>
