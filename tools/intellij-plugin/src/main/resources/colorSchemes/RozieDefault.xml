<scheme name="Default" version="142" parent_scheme="Default">
    <attributes>
        <!-- Neutralize the default INJECTED_LANGUAGE_FRAGMENT background tint.
             Empty <value/> clears all attribute overrides so the editor's
             normal foreground/background apply.  Every Rozie SFC block
             (<script>, <style>, <props>, <data>, <components>, <listeners>)
             is a language-injection target; without this override every
             .rozie file shows a distracting per-block backdrop.  Vue's plugin
             ships an equivalent override (colorSchemes/VueDefault.xml). -->
        <option name="INJECTED_LANGUAGE_FRAGMENT">
            <value/>
        </option>
        <!-- Component reference (PascalCase tag) — bold dark teal, distinct from
             the light theme's HTML tag-name color so <Modal>/<Card> read as
             components, not plain markup. User-overridable via Settings → Editor
             → Color Scheme → Rozie. -->
        <option name="ROZIE_COMPONENT_REF">
            <value>
                <option name="FOREGROUND" value="267f99"/>
                <option name="FONT_TYPE" value="1"/>
            </value>
        </option>
    </attributes>
</scheme>
