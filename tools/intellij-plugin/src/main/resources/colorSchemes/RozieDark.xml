<scheme name="Dark" version="142" parent_scheme="Dark">
    <attributes>
        <!-- New-UI "Dark" scheme companion to RozieDarcula.xml. The new UI
             defaults to the "Dark" editor color scheme (a distinct scheme from
             classic "Darcula"), which does NOT inherit the Darcula override —
             so without this entry every .rozie block shows the
             INJECTED_LANGUAGE_FRAGMENT backdrop on the default dark theme.
             Empty <value/> clears the attribute so the editor's normal
             background applies. -->
        <option name="INJECTED_LANGUAGE_FRAGMENT">
            <value/>
        </option>
        <!-- Component reference (PascalCase tag) — bold teal, distinct from the
             dark theme's HTML tag-name color. User-overridable via Settings →
             Editor → Color Scheme → Rozie. -->
        <option name="ROZIE_COMPONENT_REF">
            <value>
                <option name="FOREGROUND" value="4ec9b0"/>
                <option name="FONT_TYPE" value="1"/>
            </value>
        </option>
    </attributes>
</scheme>
