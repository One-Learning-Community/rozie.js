<scheme name="Darcula" version="142" parent_scheme="Darcula">
    <attributes>
        <!-- Darcula companion to RozieDefault.xml — neutralizes the
             INJECTED_LANGUAGE_FRAGMENT backdrop on the dark theme. -->
        <option name="INJECTED_LANGUAGE_FRAGMENT">
            <value/>
        </option>
        <!-- Component reference (PascalCase tag) — bold teal, clearly distinct
             from Darcula's yellow HTML tag-name color so <Modal>/<Card> read as
             components, not plain markup. User-overridable via Settings → Editor
             → Color Scheme → Rozie. -->
        <option name="ROZIE_COMPONENT_REF">
            <value>
                <option name="FOREGROUND" value="4ec9b0"/>
                <option name="FONT_TYPE" value="1"/>
            </value>
        </option>
    </attributes>
</scheme>
