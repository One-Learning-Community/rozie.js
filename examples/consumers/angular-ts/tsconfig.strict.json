{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "emitDecoratorMetadata": true
  },
  "include": ["test.ts", "flatpickr-forms.probe.ts", "fixtures/**/*.ts"]
}
