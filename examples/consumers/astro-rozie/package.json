{
  "name": "astro-rozie-demo",
  "version": "0.0.0",
  "private": true,
  "description": "Smoke test: Rozie compiled inside an Astro 5 project via the Vite plugin slot. Targets Lit so islands ship as native Web Components with the smallest per-island runtime. Mirrors what 'npm create astro@latest' produces, with the Rozie unplugin wired in per docs/guide/adopt-incrementally.md.",
  "type": "module",
  "scripts": {
    "build": "astro build",
    "preview": "astro preview --port 4178",
    "test:smoke": "vitest run --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@astrojs/solid-js": "^5.1.3",
    "@astrojs/svelte": "^7.2.5",
    "@astrojs/vue": "^5.1.4",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@rozie/runtime-lit": "workspace:*",
    "@rozie/runtime-react": "workspace:*",
    "@rozie/runtime-solid": "workspace:*",
    "@rozie/runtime-svelte": "workspace:*",
    "@rozie/runtime-vue": "workspace:*",
    "@rozie/unplugin": "workspace:*",
    "astro": "^5.0.0",
    "lit": "^3.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "solid-js": "^1.9.12",
    "svelte": "^5.0.0",
    "vue": "^3.5.24"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  }
}
