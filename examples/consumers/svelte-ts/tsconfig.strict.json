{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "verbatimModuleSyntax": true,
    "types": ["svelte"]
  },
  "include": ["test.ts", "fixtures/**/*.svelte", "fixtures/**/*.ts"],
  "exclude": [
    "fixtures/TodoList.svelte",
    "fixtures/Dropdown.svelte",
    "fixtures/SearchInput.svelte"
  ]
}
