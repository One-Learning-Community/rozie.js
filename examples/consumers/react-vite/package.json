{
  "name": "react-vite-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:swc": "vite build --config vite.config.swc.ts",
    "preview": "vite preview --port 4174",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:swc": "VITE_USE_SWC=1 playwright test",
    "test:e2e:hmr": "playwright test --config playwright.hmr.config.ts",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@rozie/runtime-lit": "workspace:*",
    "@rozie/runtime-react": "workspace:*",
    "@rozie/unplugin": "workspace:*",
    "lit": "^3.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@types/node": "^20",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4",
    "@vitejs/plugin-react-swc": "^4",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "playwright": "^1",
    "source-map-js": "^1.2.1",
    "typescript": "^5.6",
    "vite": "^5"
  }
}
