{
  "name": "react-vite-demo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:swc": "vite build --config vite.config.swc.ts",
    "preview": "vite preview --port 4174",
    "typecheck": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:swc": "VITE_USE_SWC=1 playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@rozie/runtime-react": "workspace:*",
    "@rozie/unplugin": "workspace:*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "@vitejs/plugin-react-swc": "^3",
    "eslint": "^9",
    "eslint-plugin-react-hooks": "^5",
    "playwright": "^1",
    "source-map-js": "^1.2.1",
    "typescript": "^5",
    "vite": "^5"
  }
}
