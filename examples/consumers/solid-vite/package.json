  },
  "devDependencies": {
    "@playwright/test": "^1",
    "playwright": "^1",
    "source-map-js": "^1.2.1",
    "typescript": "^5.6",
    "vite": "^8",
    "vite-plugin-solid": "^2.11.12"
  }
