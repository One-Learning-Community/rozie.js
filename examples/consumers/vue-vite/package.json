    "@rozie/unplugin": "workspace:*",
    "lit": "^3.2.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1",
    "@vitejs/plugin-vue": "^5",
    "playwright": "^1",
    "source-map-js": "^1.2.1",
