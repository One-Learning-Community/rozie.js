<rozie name="WrapperModal">

<components>
{
  Modal: './Modal.rozie',
}
</components>

<props>
{
  title: { type: String, default: 'Wrapped' },
}
</props>

<template>
<Modal :open="true" :title="$props.title">
  <template #header>
    <slot name="brand">
      <h2>{{ $props.title }}</h2>
    </slot>
  </template>
  <slot />
  <template #footer>
    <slot name="actions" />
  </template>
</Modal>
</template>

</rozie>
