<rozie name="PartialInlineHostK">

<props>
{
  base: { type: Number, default: 1 },
}
</props>

<script lang="ts">
const tickK = () => $props.base * 2;
import { ariaSortK, sortIndicatorK } from './partialLogicK.rzts';
</script>

<template>
<div class="partial-inline-host">
  <span class="echo">{{ ariaSortK(1) }}</span>
  <span class="echo">{{ sortIndicatorK(1) }}</span>
</div>
