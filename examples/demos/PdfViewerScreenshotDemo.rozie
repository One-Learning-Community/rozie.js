<!--
  PdfViewerScreenshotDemo.rozie — content-STABLE screenshot consumer for the
  PdfViewer wrapper (the PDF-canvas-VR cell).

  Where PdfViewerDemo.rozie is the BEHAVIORAL dynamic-import + two-way-page + Next
  cell, THIS is the SEPARATE deterministic SCREENSHOT cell — never extend it for
  behavior, and never bolt pixels onto the behavioral one.

  pdfjs rasterizes the PDF page into a 2D <canvas> from the SAME pdfjs-dist v6 in
  every target, so the bitmap is engine-painted and emit-family-independent — a
  stable, byte-identical-across-targets baseline CAN exist (the same canvas-VR
  property the Chart cell relies on; the earlier "canvas-VR byte-identity won't
  hold" worry was disproven once the Chart and MapLibre canvas cells landed 6/6).

  Determinism levers:
    1. A self-contained 3-page base64 PDF data URL (network-free, identical in
       Docker) — same SAMPLE as the behavioral demo, pinned to PAGE 1.
    2. :worker-src is the Vite-BUNDLED worker (a static `?url` import), NOT the
       wrapper's default CDN — Docker/CI has NO network. (The standard-font CDN is
       likewise unreachable in Docker; pdfjs falls back deterministically, the same
       way for all 6 targets, so the rendered glyphs are identical across the cell.)
    3. :text-layer="false" — drop the selectable-text HTML overlay so the capture is
       ONLY the deterministic canvas bitmap (the textLayer's positioned spans +
       --scale-factor would add a font-rendered DOM layer that can drift).
    4. A FIXED :page="1" + :scale (primitive literals — no array-identity churn) and
       a fixed-pixel container, so the layout is deterministic.

  One .rozie source compiles to six per-framework screenshot consumers; the Linux
  PNG baseline is generated by the orchestrator in pinned Linux Docker (NOT here —
  macOS baselines are forbidden, feedback_vr_linux_baselines). Until it lands the
  matrix cell auto-fixmes on baselineExists().
-->

<rozie name="PdfViewerScreenshotDemo">

<components>
{
  PdfViewer: '../../packages/ui/pdf/src/PdfViewer.rozie',
}
</components>

<script>
// Bundle the PDF.js worker locally — Docker/CI has NO network, so the wrapper's
// default CDN workerSrc would fail. A static `?url` import (Vite resolves it at
// build time) is the offline-safe form (the same one the behavioral demo uses).
import workerSrc from 'pdfjs-dist/build/pdf.worker.min.mjs?url'

// A self-contained 3-page PDF (base64 data URL) — network-free. Page 1 reads
// "Rozie PDF viewer - page 1" + a pangram. Copied verbatim from PdfViewerDemo.
const SAMPLE = 'data:application/pdf;base64,'
</script>

<template>
<div class="pdf-screenshot-demo">
  <div class="box">
    <PdfViewer
      :src="SAMPLE"
      :worker-src="workerSrc"
      :page="1"
      :scale="0.45"
      :text-layer="false"
    />
  </div>
</div>
</template>

<style>
.pdf-screenshot-demo {
  font-family: system-ui, -apple-system, sans-serif;
  color: #1a1a1a;
  padding: 1rem;
  max-width: 720px;
}
.pdf-screenshot-demo .box {
  width: 280px;
  height: 364px;
  border: 1px solid rgba(0, 0, 0, 0.12);
  border-radius: 4px;
  overflow: hidden;
  background: #f5f5f5;
}
</style>

</rozie>
