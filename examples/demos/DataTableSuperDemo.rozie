      <code data-slice="columnVisibility">columnVisibility: {{ JSON.stringify($data.columnVisibility) }}</code>
      <code data-slice="columnSizing">columnSizing: {{ JSON.stringify($data.columnSizing) }}</code>
      <code data-slice="columnOrder">columnOrder: {{ JSON.stringify($data.columnOrder) }}</code>
      <code data-slice="columnPinning">columnPinning: {{ JSON.stringify($data.columnPinning) }}</code>
      <code data-slice="lastCommit">lastCommit: {{ JSON.stringify($data.lastCommit) }}</code>
    </aside>
  </main>
