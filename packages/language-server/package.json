{
  "name": "@rozie/language-server",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "rozie-language-server": "./dist/bin.cjs"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "build:standalone": "tsdown --config tsdown.standalone.config.ts",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rozie/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  },
  "license": "MIT"
}
