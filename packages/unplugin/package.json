{
  "name": "@rozie/unplugin",
  "version": "0.1.4",
  "description": "Universal build-tool plugin for Rozie.js \u2014 compile .rozie files in Vite, Rollup, Webpack, esbuild, Rolldown, and Rspack from one factory.",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./vite": {
      "types": "./src/vite.ts",
      "import": "./dist/vite.mjs",
      "require": "./dist/vite.cjs"
    },
    "./rollup": {
      "types": "./src/rollup.ts",
      "import": "./dist/rollup.mjs",
      "require": "./dist/rollup.cjs"
    },
    "./webpack": {
      "types": "./src/webpack.ts",
      "import": "./dist/webpack.mjs",
      "require": "./dist/webpack.cjs"
    },
    "./esbuild": {
      "types": "./src/esbuild.ts",
      "import": "./dist/esbuild.mjs",
      "require": "./dist/esbuild.cjs"
    },
    "./rolldown": {
      "types": "./src/rolldown.ts",
      "import": "./dist/rolldown.mjs",
      "require": "./dist/rolldown.cjs"
    },
    "./rspack": {
      "types": "./src/rspack.ts",
      "import": "./dist/rspack.mjs",
      "require": "./dist/rspack.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@rozie/core": "workspace:*",
    "@vue/compiler-sfc": "^3.5.33",
    "htmlparser2": "^12.0.0",
    "magic-string": "^0.30.21",
    "picocolors": "^1.1.0",
    "postcss": "^8.5.13",
    "unplugin": "^3.0.0",
    "@rozie/runtime-vue": "workspace:*",
    "@rozie/runtime-react": "workspace:*"
  },
  "peerDependencies": {
    "@vitejs/plugin-vue": "^5 || ^6",
    "@vitejs/plugin-react": "^4 || ^5",
    "@vitejs/plugin-react-swc": "^3 || ^4",
    "vue": "^3.4",
    "react": "^18.2 || ^19"
  },
  "peerDependenciesMeta": {
    "@rozie/runtime-vue": {
      "optional": false
    },
    "@rozie/runtime-react": {
      "optional": true
    },
    "@vitejs/plugin-vue": {
      "optional": false
    },
    "@vitejs/plugin-react": {
      "optional": true
    },
    "@vitejs/plugin-react-swc": {
      "optional": true
    },
    "vue": {
      "optional": false
    },
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rozie/target-angular": "workspace:*",
    "@rozie/target-lit": "workspace:*",
    "@rozie/target-react": "workspace:*",
    "@rozie/target-solid": "workspace:*",
    "@rozie/target-svelte": "workspace:*",
    "@rozie/target-vue": "workspace:*",
    "@vitejs/plugin-vue": "^6.0.6",
    "esbuild": "^0.27.0",
    "memfs": "^4.0.0",
    "rolldown": "^1.0.0-rc.17",
    "rollup": "^4.0.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "webpack": "^5.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/unplugin"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "author": "One Learning Community (https://github.com/One-Learning-Community)"
}