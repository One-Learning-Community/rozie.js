{
  "name": "@rozie/runtime-react",
  "version": "0.1.1",
  "description": "React runtime helpers for Rozie.js-compiled components (slot projection and class-merge utilities).",
  "type": "module",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts"
  ],
  "dependencies": {
    "clsx": "^2",
    "style-to-js": "^2.0.0"
  },
  "peerDependencies": {
    "react": "^18.2 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@testing-library/react": "^16",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "happy-dom": "^15.0.0",
    "postcss": "^8.5.13",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/runtime/react"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  }
}
