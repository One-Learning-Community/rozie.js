{
  "name": "@rozie/runtime-engine-helpers",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Rozie maintainers",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "sortablejs": "^1.15"
  },
  "peerDependenciesMeta": {
    "sortablejs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/sortablejs": "^1.15.8",
    "@vitest/coverage-v8": "4.1.5",
    "happy-dom": "^15.0.0",
    "sortablejs": "^1.15.7",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  }
}
