{
  "name": "@rozie/runtime-lit",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "author": "Rozie maintainers",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "lit": "^3.2.0"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    }
  },
  "devDependencies": {
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^9.39.4",
    "happy-dom": "^15.0.0",
    "lit": "^3.2.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
