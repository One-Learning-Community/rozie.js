{
  "name": "@rozie/runtime-svelte",
  "version": "0.1.1",
  "description": "Svelte runtime helpers for Rozie.js-compiled components (slot projection and class-merge utilities).",
  "type": "module",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "exports": {
    ".": {
      "svelte": "./src/index.ts",
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./PortalHost.svelte": "./src/PortalHost.svelte",
    "./PortalHostReactive.svelte": "./src/PortalHostReactive.svelte",
    "./applyListeners": {
      "svelte": "./src/applyListeners.ts",
      "types": "./src/applyListeners.ts",
      "import": "./src/applyListeners.ts",
      "default": "./src/applyListeners.ts"
    }
  },
  "files": [
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts"
  ],
  "peerDependencies": {
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    }
  },
  "devDependencies": {
    "svelte": "^5",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "echo 'svelte runtime ships source; no build'",
    "typecheck": "echo 'svelte runtime: source-only, no typecheck'"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/runtime/svelte"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  }
}
