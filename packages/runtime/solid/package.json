  "files": ["dist", "src"],
  "peerDependencies": {
    "solid-js": "^1.8"
  },
  "peerDependenciesMeta": {
    "solid-js": { "optional": false }
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "happy-dom": "^15.0.0",
    "solid-js": "^1.9.12",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  }
}
