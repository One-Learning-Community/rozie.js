{
  "name": "@rozie/runtime-solid",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Rozie maintainers",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
