{
  "name": "@rozie/runtime-keynav-core",
  "version": "0.2.1",
  "description": "Framework-neutral r-keynav state machine, class-token normalizer, and windower contract — the pure-TS core every per-target Rozie.js keynav controller (React/Vue/Svelte/Solid/Lit hooks + the Angular inline controller) imports.",
  "type": "module",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/runtime/keynav-core"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  }
}
