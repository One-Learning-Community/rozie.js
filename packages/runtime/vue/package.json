{
  "name": "@rozie/runtime-vue",
  "version": "0.1.4",
  "description": "Vue runtime helpers for Rozie.js-compiled components (slot projection and class-merge utilities).",
  "type": "module",
  "sideEffects": false,
  "private": false,
  "license": "MIT",
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rozie/runtime-keynav-core": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^15.0.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0",
    "vue": "^3.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/runtime/vue"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  }
}
