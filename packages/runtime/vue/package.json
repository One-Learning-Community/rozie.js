{
  "name": "@rozie/runtime-vue",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "license": "MIT",
  "author": "Rozie maintainers",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=html",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.5",
    "@vue/test-utils": "^2.4.0",
    "happy-dom": "^15.0.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0",
    "vue": "^3.4.0"
  }
}
