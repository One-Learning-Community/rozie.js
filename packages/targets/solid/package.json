{
  "name": "@rozie/target-solid",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "src"],
  "dependencies": {
    "@ampproject/remapping": "^2.3.0",
    "@babel/generator": "^7.29",
    "@babel/parser": "^7.29",
    "@babel/traverse": "^7.29",
    "@babel/types": "^7.29",
    "@rozie/core": "workspace:*",
    "magic-string": "^0.30",
    "postcss": "^8.5"
  },
  "peerDependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__generator": "^7",
    "@types/babel__traverse": "^7",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9",
    "happy-dom": "^15.0.0",
    "solid-js": "^1.9.12",
    "source-map-js": "^1.2.1",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
