<>
<div {...attrs} className={clsx(clsx(styles.counter, { [styles.hovering]: hovering }), (attrs.className as string | undefined))} {...mergeListeners({ onMouseEnter: ($event) => { setHovering(true); }, onMouseLeave: ($event) => { setHovering(false); } }, $listeners)}>
  <button disabled={!canDecrement} aria-label="Decrement" onClick={decrement}>−</button>
  <span className={styles.value}>{value}</span>
  <button disabled={!canIncrement} aria-label="Increment" onClick={increment}>+</button>
</div>
</>