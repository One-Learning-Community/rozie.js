<>
<div {...attrs} className={clsx(clsx("counter", { hovering: hovering }), (attrs.className as string | undefined))} onMouseEnter={($event) => { setHovering(true); }} onMouseLeave={($event) => { setHovering(false); }}>
  <button disabled={!canDecrement} aria-label="Decrement" onClick={decrement}>−</button>
  <span className={"value"}>{value}</span>
  <button disabled={!canIncrement} aria-label="Increment" onClick={increment}>+</button>
</div>
</>