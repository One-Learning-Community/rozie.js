<>
<div {...attrs} className={clsx("search-input", (attrs.className as string | undefined))}>
  
  <input ref={inputEl} type="search" placeholder={props.placeholder} value={query} onChange={e => setQuery(e.target.value)} onInput={_rozieDebouncedOnSearch} onKeyDown={($event) => { (($event) => { if ($event.key !== 'Enter') return; ((onSearch) as ((...args: any[]) => any))($event); })($event); (($event) => { if ($event.key !== 'Escape') return; ((clear) as ((...args: any[]) => any))($event); })($event); }} />

  {(query.length > 0) ? <button className={"clear-btn"} aria-label="Clear" onClick={clear}>
    ×
  </button> : <span className={"hint"}>{props.minLength}+ chars</span>}</div>
</>