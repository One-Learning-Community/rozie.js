{
  "name": "@rozie/target-svelte",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@babel/generator": "^7.29",
    "@babel/parser": "^7.29",
    "@babel/traverse": "^7.29",
    "@babel/types": "^7.29",
    "@rozie/core": "workspace:*",
    "magic-string": "^0.30",
    "postcss": "^8.5"
  },
  "devDependencies": {
    "@types/babel__generator": "^7",
    "@types/babel__traverse": "^7",
    "happy-dom": "^15",
    "svelte": "^5.0.0",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.0"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "build": "tsdown",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT"
}
