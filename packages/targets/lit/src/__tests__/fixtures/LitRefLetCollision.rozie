<!--
  LitRefLetCollision.rozie — emitter-hardening backlog item #9, Lit half.

  A module-scope capture-`let` whose name is IDENTICAL to a template
  `ref="canvasEl"` name. `canvasEl` is populated inside `$onMount` from a
  NON-`$refs` source (`new FakeEngine()` — never `$refs.canvasEl`, so this
  reproduces independent of any `$refs`-read detection path) and read from a
  second lifecycle path (the `$onMount` cleanup return AND a top-level
  `recreate()` helper invoked from `$watch`) — genuinely promoting the let to
  a real class field, mirroring `packages/ui/chartjs/src/Chart.rozie`'s
  `canvasNode`/`ref="canvasEl"` shape (that file's workaround renames the let
  to dodge this exact bug).

  Per `collectMethodNamesFromProgram`'s Spike-012 R3-5 note (rewriteScript.ts
  ~165-172), `$refs.X` lowers to the PREFIXED `_refX` @query field, so a
  same-named top-level user binding is NOT excluded from the promoted-field
  set — it is a genuine class field whose every reference must this-qualify
  to `this.canvasEl`. This fixture pins the surviving BARE `canvasEl`
  reference(s) that currently slip through un-qualified (TS2663).
-->
<rozie name="LitRefLetCollision">

<props>
{ kind: { type: String, default: 'line' } }
</props>

<script>
class FakeEngine {
  destroy() {}
}

// Populated from `new FakeEngine()`, NEVER from `$refs.canvasEl` — isolates
// the promoted-class-field this-qualification bug from any `$refs`-read
// detection path.
let canvasEl = null

$onMount(() => {
  canvasEl = new FakeEngine()
  return () => {
    canvasEl.destroy()
  }
})

const recreate = () => {
  if (!canvasEl) return
  canvasEl.destroy()
  canvasEl = new FakeEngine()
}

$watch(() => $props.kind, () => recreate())
</script>

<template>
  <canvas ref="canvasEl"></canvas>
</template>

</rozie>
