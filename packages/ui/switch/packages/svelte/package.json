{
  "name": "@rozie-ui/switch-svelte",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte headless WAI-ARIA toggle / switch (role=\"switch\", boolean two-way value, click + Space/Enter keyboard, token theming) — one accessible Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "switch",
    "toggle",
    "checkbox",
    "form-control",
    "switch-input",
    "headless",
    "accessibility",
    "aria",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/switch/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/Switch.svelte",
      "types": "./dist/Switch.svelte.d.ts",
      "default": "./dist/Switch.svelte"
    },
    "./themes/*": "./src/themes/*",
    "./source": {
      "svelte": "./src/Switch.svelte",
      "default": "./src/Switch.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
