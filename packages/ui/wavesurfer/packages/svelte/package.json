{
  "name": "@rozie-ui/wavesurfer-svelte",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte audio waveform player wrapping wavesurfer.js — one Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "wavesurfer.js",
    "wavesurfer",
    "audio",
    "waveform",
    "player",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/wavesurfer/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/Waveform.svelte",
      "types": "./dist/Waveform.svelte.d.ts",
      "default": "./dist/Waveform.svelte"
    },
    "./source": {
      "svelte": "./src/Waveform.svelte",
      "default": "./src/Waveform.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "wavesurfer.js": "^7"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "wavesurfer.js": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
