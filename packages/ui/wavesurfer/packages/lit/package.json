{
  "name": "@rozie-ui/wavesurfer-lit",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit audio waveform player wrapping wavesurfer.js — one Rozie source compiled to Lit.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "wavesurfer.js",
    "wavesurfer",
    "audio",
    "waveform",
    "player",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/wavesurfer/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "wavesurfer.js": "^7"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "wavesurfer.js": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
