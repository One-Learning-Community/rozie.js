{
  "name": "@rozie-ui/data-table-lit",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit headless WAI-ARIA data table (sorting, filtering, pagination, selection, column visibility/resize/reorder/pinning) on @tanstack/table-core — one accessible Rozie source compiled to Lit.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "data-table",
    "table",
    "datagrid",
    "tanstack-table",
    "table-core",
    "headless",
    "accessibility",
    "aria",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/data-table/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.2",
    "@lit/context": "^1.1",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@tanstack/table-core": "^8.21",
    "@tanstack/virtual-core": "^3",
    "@rozie-ui/popover-lit": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit/context": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "@tanstack/table-core": {
      "optional": false
    },
    "@tanstack/virtual-core": {
      "optional": false
    },
    "@rozie-ui/popover-lit": {
      "optional": false
    }
  },
  "devDependencies": {},
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ]
}
