{
  "name": "@rozie-ui/data-table-vue",
  "version": "0.2.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue headless WAI-ARIA data table (sorting, filtering, pagination, selection, column visibility/resize/reorder/pinning) on @tanstack/table-core — one accessible Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "data-table",
    "table",
    "datagrid",
    "tanstack-table",
    "table-core",
    "headless",
    "accessibility",
    "aria",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/data-table/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-vue": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.4",
    "@tanstack/table-core": "^8.21",
    "@tanstack/virtual-core": "^3",
    "@rozie-ui/popover-vue": "^0.1.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "@tanstack/table-core": {
      "optional": false
    },
    "@tanstack/virtual-core": {
      "optional": false
    },
    "@rozie-ui/popover-vue": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ],
  "devDependencies": {
    "@tanstack/table-core": "^8.21",
    "@tanstack/virtual-core": "^3",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
