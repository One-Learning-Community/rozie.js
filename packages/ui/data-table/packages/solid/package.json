{
  "name": "@rozie-ui/data-table-solid",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid headless WAI-ARIA data table (sorting, filtering, pagination, selection, column visibility/resize/reorder/pinning) on @tanstack/table-core — one accessible Rozie source compiled to Solid.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "data-table",
    "table",
    "datagrid",
    "tanstack-table",
    "table-core",
    "headless",
    "accessibility",
    "aria",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/data-table/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*",
    "@solid-primitives/keyed": "^1.5.3"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "@tanstack/table-core": "^8.21",
    "@tanstack/virtual-core": "^3",
    "@floating-ui/dom": "^1.7.2"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "@tanstack/table-core": {
      "optional": false
    },
    "@tanstack/virtual-core": {
      "optional": false
    },
    "@floating-ui/dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.7.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ]
}
