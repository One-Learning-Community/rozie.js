{
  "name": "@rozie-ui/command-palette-solid",
  "version": "0.3.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid headless WAI-ARIA cmdk-style command palette (portal overlay, search filter, keyboard navigation) — one accessible Rozie source compiled to Solid.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "command-palette",
    "command-menu",
    "cmdk",
    "command-k",
    "palette",
    "spotlight",
    "headless",
    "accessibility",
    "aria",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/command-palette/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/CommandPalette.tsx",
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*",
    "@solid-primitives/keyed": "^1.5.3"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "@rozie-ui/combobox-solid": "^0.3.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "@rozie-ui/combobox-solid": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
