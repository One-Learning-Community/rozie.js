{
  "name": "@rozie-ui/command-palette-svelte",
  "version": "0.4.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte headless WAI-ARIA cmdk-style command palette (portal overlay, search filter, keyboard navigation) — one accessible Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "command-palette",
    "command-menu",
    "cmdk",
    "command-k",
    "palette",
    "spotlight",
    "headless",
    "accessibility",
    "aria",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/command-palette/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/CommandPalette.svelte",
      "types": "./dist/CommandPalette.svelte.d.ts",
      "default": "./dist/CommandPalette.svelte"
    },
    "./themes/*": "./src/themes/*",
    "./source": {
      "svelte": "./src/CommandPalette.svelte",
      "default": "./src/CommandPalette.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "@rozie-ui/combobox-svelte": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@rozie-ui/combobox-svelte": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@rozie-ui/command-palette": "workspace:*",
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
