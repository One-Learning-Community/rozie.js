{
  "name": "@rozie-ui/command-palette-react",
  "version": "0.4.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic React headless WAI-ARIA cmdk-style command palette (portal overlay, search filter, keyboard navigation) — one accessible Rozie source compiled to React.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "command-palette",
    "command-menu",
    "cmdk",
    "command-k",
    "palette",
    "spotlight",
    "headless",
    "accessibility",
    "aria",
    "component",
    "react"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/command-palette/packages/react"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/CommandPalette.tsx",
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2 || ^19",
    "react-dom": "^18.2 || ^19",
    "@rozie-ui/combobox-react": "^0.4.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "@rozie-ui/combobox-react": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
