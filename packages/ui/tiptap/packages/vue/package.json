{
  "name": "@rozie-ui/tiptap-vue",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue rich-text editor — one Rozie source compiled to Vue wrapping TipTap.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "tiptap",
    "editor",
    "rich-text-editor",
    "prosemirror",
    "wysiwyg",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/tiptap/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/TipTap.vue",
      "default": "./src/TipTap.vue"
    }
  },
  "files": [
    "dist",
    "src",
    "web-types.json"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "@tiptap/core": "^3",
    "@tiptap/extensions": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-character-count": "^3",
    "@tiptap/extension-floating-menu": "^3",
    "@tiptap/extension-image": "^3",
    "@tiptap/starter-kit": "^3"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "@tiptap/core": {
      "optional": false
    },
    "@tiptap/extensions": {
      "optional": false
    },
    "@tiptap/extension-bubble-menu": {
      "optional": true
    },
    "@tiptap/extension-character-count": {
      "optional": true
    },
    "@tiptap/extension-floating-menu": {
      "optional": true
    },
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@tiptap/core": "^3",
    "@tiptap/extensions": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-character-count": "^3",
    "@tiptap/extension-floating-menu": "^3",
    "@tiptap/extension-image": "^3",
    "@tiptap/starter-kit": "^3",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  },
  "web-types": "./web-types.json"
}
