{
  "name": "@rozie-ui/tiptap-svelte",
  "version": "0.2.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte rich-text editor — one Rozie source compiled to Svelte wrapping TipTap.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "tiptap",
    "editor",
    "rich-text-editor",
    "prosemirror",
    "wysiwyg",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/tiptap/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/TipTap.svelte",
      "types": "./dist/TipTap.svelte.d.ts",
      "default": "./dist/TipTap.svelte"
    },
    "./source": {
      "svelte": "./src/TipTap.svelte",
      "default": "./src/TipTap.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "@tiptap/core": "^3",
    "@tiptap/extensions": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-character-count": "^3",
    "@tiptap/extension-floating-menu": "^3",
    "@tiptap/extension-image": "^3",
    "@tiptap/starter-kit": "^3"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@tiptap/core": {
      "optional": false
    },
    "@tiptap/extensions": {
      "optional": false
    },
    "@tiptap/extension-bubble-menu": {
      "optional": true
    },
    "@tiptap/extension-character-count": {
      "optional": true
    },
    "@tiptap/extension-floating-menu": {
      "optional": true
    },
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
