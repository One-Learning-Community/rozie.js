{
  "name": "@rozie-ui/tiptap-solid",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid rich-text editor — one Rozie source compiled to Solid wrapping TipTap.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "tiptap",
    "editor",
    "rich-text-editor",
    "prosemirror",
    "wysiwyg",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/tiptap/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "@tiptap/core": "^3",
    "@tiptap/extensions": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-floating-menu": "^3",
    "@tiptap/starter-kit": "^3"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "@tiptap/core": {
      "optional": false
    },
    "@tiptap/extensions": {
      "optional": false
    },
    "@tiptap/extension-bubble-menu": {
      "optional": true
    },
    "@tiptap/extension-floating-menu": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
