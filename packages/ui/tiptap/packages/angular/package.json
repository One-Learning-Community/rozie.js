{
  "name": "@rozie-ui/tiptap-angular",
  "version": "0.2.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Angular rich-text editor — one Rozie source compiled to Angular wrapping TipTap.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "tiptap",
    "editor",
    "rich-text-editor",
    "prosemirror",
    "wysiwyg",
    "component",
    "angular"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/tiptap/packages/angular"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/rozie-ui-tiptap-angular.mjs"
    },
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@angular/core": "^19",
    "@angular/common": "^19",
    "@angular/forms": "^19",
    "@tiptap/core": "^3",
    "@tiptap/extensions": "^3",
    "@tiptap/extension-bubble-menu": "^3",
    "@tiptap/extension-character-count": "^3",
    "@tiptap/extension-floating-menu": "^3",
    "@tiptap/extension-image": "^3",
    "@tiptap/starter-kit": "^3"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    },
    "@angular/common": {
      "optional": false
    },
    "@angular/forms": {
      "optional": false
    },
    "@tiptap/core": {
      "optional": false
    },
    "@tiptap/extensions": {
      "optional": false
    },
    "@tiptap/extension-bubble-menu": {
      "optional": true
    },
    "@tiptap/extension-character-count": {
      "optional": true
    },
    "@tiptap/extension-floating-menu": {
      "optional": true
    },
    "@tiptap/extension-image": {
      "optional": true
    },
    "@tiptap/starter-kit": {
      "optional": false
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "typecheck": "echo 'source+dist; ng-packagr declaration emit at build'"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/fesm2022/rozie-ui-tiptap-angular.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/forms": "^19",
    "ng-packagr": "^19",
    "typescript": "~5.6.0"
  }
}
