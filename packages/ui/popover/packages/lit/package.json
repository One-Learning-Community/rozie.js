{
  "name": "@rozie-ui/popover-lit",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit popover/tooltip wrapping @floating-ui/dom — one Rozie source compiled to Lit.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "floating-ui",
    "popover",
    "tooltip",
    "dropdown",
    "positioning",
    "headless",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/popover/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./themes/*": "./src/themes/*",
    "./rozie-manifest.json": "./rozie-manifest.json"
  },
  "files": [
    "dist",
    "src",
    "rozie-manifest.json"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@floating-ui/dom": "^1.7.2"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "@floating-ui/dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.7.2"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
