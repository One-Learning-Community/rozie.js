{
  // strictNullChecks/exactOptionalPropertyTypes/noImplicitAny relaxed: the emitted
  // Solid output is bundler-built (tsdown/oxc), not strict-tsc-authored. No `paths`
  // alias for `@floating-ui/dom`: the published package ships real types.
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "noImplicitOverride": false,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
