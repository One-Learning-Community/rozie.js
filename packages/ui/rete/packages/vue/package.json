{
  "name": "@rozie-ui/rete-vue",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue node-based flow/graph editor wrapping Rete.js v2 — one Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "rete",
    "rete-js",
    "node-editor",
    "flow",
    "graph",
    "diagram",
    "nodes",
    "visual-programming",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/rete/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-vue": "workspace:^"
  },
  "peerDependencies": {
    "vue": "^3.4",
    "rete": "^2",
    "rete-area-plugin": "^2",
    "rete-connection-plugin": "^2",
    "rete-render-utils": "^2",
    "rete-auto-arrange-plugin": "^2.0.2",
    "elkjs": "^0.8.2",
    "web-worker": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "rete": {
      "optional": false
    },
    "rete-area-plugin": {
      "optional": false
    },
    "rete-connection-plugin": {
      "optional": false
    },
    "rete-render-utils": {
      "optional": false
    },
    "rete-auto-arrange-plugin": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    },
    "web-worker": {
      "optional": true
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "rete": "^2",
    "rete-area-plugin": "^2",
    "rete-connection-plugin": "^2",
    "rete-render-utils": "^2",
    "rete-auto-arrange-plugin": "^2.0.2",
    "elkjs": "^0.8.2",
    "web-worker": "^1.2.0",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
