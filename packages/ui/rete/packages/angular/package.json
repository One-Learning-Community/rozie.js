{
  "name": "@rozie-ui/rete-angular",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Angular node-based flow/graph editor wrapping Rete.js v2 — one Rozie source compiled to Angular.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "rete",
    "rete-js",
    "node-editor",
    "flow",
    "graph",
    "diagram",
    "nodes",
    "visual-programming",
    "angular"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/rete/packages/angular"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/rozie-ui-rete-angular.mjs"
    },
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@angular/core": "^19 || ^20 || ^21",
    "@angular/common": "^19 || ^20 || ^21",
    "rete": "^2",
    "rete-area-plugin": "^2",
    "rete-connection-plugin": "^2",
    "rete-render-utils": "^2",
    "rete-auto-arrange-plugin": "^2.0.2",
    "elkjs": "^0.8.2",
    "web-worker": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    },
    "@angular/common": {
      "optional": false
    },
    "rete": {
      "optional": false
    },
    "rete-area-plugin": {
      "optional": false
    },
    "rete-connection-plugin": {
      "optional": false
    },
    "rete-render-utils": {
      "optional": false
    },
    "rete-auto-arrange-plugin": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    },
    "web-worker": {
      "optional": true
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "typecheck": "echo 'source+dist; ng-packagr declaration emit at build'"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "module": "./dist/fesm2022/rozie-ui-rete-angular.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/forms": "^19",
    "ng-packagr": "^19",
    "typescript": "~5.6.0"
  }
}
