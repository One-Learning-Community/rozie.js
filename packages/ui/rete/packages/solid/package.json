{
  "name": "@rozie-ui/rete-solid",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid node-based flow/graph editor wrapping Rete.js v2 — one Rozie source compiled to Solid.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "rete",
    "rete-js",
    "node-editor",
    "flow",
    "graph",
    "diagram",
    "nodes",
    "visual-programming",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/rete/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "rete": "^2",
    "rete-area-plugin": "^2",
    "rete-connection-plugin": "^2",
    "rete-render-utils": "^2",
    "rete-auto-arrange-plugin": "^2.0.2",
    "elkjs": "^0.8.2",
    "web-worker": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "rete": {
      "optional": false
    },
    "rete-area-plugin": {
      "optional": false
    },
    "rete-connection-plugin": {
      "optional": false
    },
    "rete-render-utils": {
      "optional": false
    },
    "rete-auto-arrange-plugin": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    },
    "web-worker": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
