{
  "name": "@rozie-ui/rete-svelte",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte node-based flow/graph editor wrapping Rete.js v2 — one Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "rete",
    "rete-js",
    "node-editor",
    "flow",
    "graph",
    "diagram",
    "nodes",
    "visual-programming",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/rete/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./source": {
      "svelte": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "rete": "^2",
    "rete-area-plugin": "^2",
    "rete-connection-plugin": "^2",
    "rete-render-utils": "^2",
    "rete-auto-arrange-plugin": "^2.0.2",
    "elkjs": "^0.8.2",
    "web-worker": "^1.2.0"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "rete": {
      "optional": false
    },
    "rete-area-plugin": {
      "optional": false
    },
    "rete-connection-plugin": {
      "optional": false
    },
    "rete-render-utils": {
      "optional": false
    },
    "rete-auto-arrange-plugin": {
      "optional": true
    },
    "elkjs": {
      "optional": true
    },
    "web-worker": {
      "optional": true
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
