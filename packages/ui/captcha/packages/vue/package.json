{
  "name": "@rozie-ui/captcha-vue",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue CAPTCHA widget wrapping Google reCAPTCHA, hCaptcha & Cloudflare Turnstile — one Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "captcha",
    "recaptcha",
    "hcaptcha",
    "turnstile",
    "bot-protection",
    "verification",
    "spam",
    "headless",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/captcha/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "peerDependencies": {
    "vue": "^3.4"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/Captcha.vue",
      "default": "./src/Captcha.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
