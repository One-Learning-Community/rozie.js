{
  "name": "@rozie-ui/captcha-svelte",
  "version": "0.1.3",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte Captcha — one Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "captcha",
    "recaptcha",
    "hcaptcha",
    "turnstile",
    "bot-protection",
    "verification",
    "spam",
    "headless",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/captcha/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/Captcha.svelte",
      "types": "./dist/Captcha.svelte.d.ts",
      "default": "./dist/Captcha.svelte"
    },
    "./RecaptchaV3": {
      "svelte": "./dist/RecaptchaV3.svelte",
      "types": "./dist/RecaptchaV3.svelte.d.ts",
      "default": "./dist/RecaptchaV3.svelte"
    },
    "./source": {
      "svelte": "./src/Captcha.svelte",
      "default": "./src/Captcha.svelte"
    },
    "./source/RecaptchaV3": {
      "svelte": "./src/RecaptchaV3.svelte",
      "default": "./src/RecaptchaV3.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  }
}
