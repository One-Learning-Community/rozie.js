{
  "name": "@rozie-ui/captcha-solid",
  "version": "0.1.3",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid CAPTCHA — Google reCAPTCHA (v2 + v3), hCaptcha, Cloudflare Turnstile & Friendly Captcha from one Rozie source.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "captcha",
    "recaptcha",
    "hcaptcha",
    "turnstile",
    "bot-protection",
    "verification",
    "spam",
    "headless",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/captcha/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/Captcha.tsx"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
