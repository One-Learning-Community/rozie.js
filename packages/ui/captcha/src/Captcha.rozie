<!--
  Captcha.rozie ‚Äî one cross-framework CAPTCHA / bot-protection widget.

  Replaces the per-framework-per-provider wrapper sprawl (react-google-recaptcha,
  vue-recaptcha, svelte-recaptcha-v2, ngx-captcha, @hcaptcha/react-hcaptcha, the
  separate Vue/Svelte hCaptcha wrappers, react-turnstile, ‚Ä¶) ‚Äî N providers √ó M
  frameworks of independently-maintained glue ‚Äî with ONE Rozie source.

  PROVIDERS (one `provider` prop). reCAPTCHA v2, hCaptcha, and Cloudflare
  Turnstile share a near-identical explicit-render API ‚Äî `api.render(el, cfg)`
  returning a widget id, `api.reset(id)`, `api.execute(id)`, `api.getResponse(id)`,
  and the `sitekey` / `theme` / `size` config keys plus `callback` /
  `expired-callback` / `error-callback`. A `{ src, global }` map per provider is
  the ONLY divergence, so one component covers those three. Friendly Captcha
  (`provider="friendly"`) is a 4th provider: its SDK exposes a different shape
  (`createWidget` returning an event-emitter handle), so its provider entry adds
  an optional `adapt()` bridge that maps `createWidget` onto the same CaptchaApi
  surface. It is loaded from the CDN compat build ‚Äî NO `@friendlycaptcha/sdk`
  npm peer dependency (the family's zero-peer-dep design). ALTCHA (a web
  component) is a different integration shape and remains a separate follow-on.

  VALUE CONTRACT (mirrors Flatpickr's model-string + rich-event pattern):
    ‚Ä¢ `token` is `model: true` ‚Äî written on success, cleared on expire/reset, so
      `r-model="token"` reflects the live response token out for form submission.
    ‚Ä¢ `@verify` fires `{ token, provider }` on success (the richer event surface);
      `@expire` and `@error` fire `{ provider }` (+ `error` on a load failure).

  SCRIPT LOADING: the provider api.js is injected ONCE per provider via a real
  cross-instance singleton on `globalThis` (a per-instance top-level const would
  not dedupe across multiple <Captcha> on a page). We poll for the global to
  appear, then `api.render($refs.widgetEl, cfg)` in $onMount.

  IMPERATIVE HANDLE ($expose): { reset, execute, getResponse }.
    ‚Ä¢ NO `render` verb ‚Äî `render()` is a LitElement lifecycle method; exposing it
      would clobber Lit's renderer (worse than Embla's scrollTo‚ÜíscrollToIndex
      inherited-method shadow). Keep render internal.
    ‚Ä¢ `execute()` drives invisible / programmatic challenges (size="invisible").
    ‚Ä¢ `getResponse()` reads the current token on demand.

  CONSTRUCTION-TIME CONFIG: these widgets cannot live-mutate sitekey/theme/size
  (there is no `set()` path) ‚Äî to retune live, re-key the component
  (`<Captcha :key="‚Ä¶">`), the same documented idiom as Flatpickr's
  construction-time options. Hence no $watch reconcilers.

  reCAPTCHA v3 (scoreless, no widget, `execute(sitekey, { action })`) is a
  genuinely different integration and is a documented follow-on; size="invisible"
  + the execute() handle already cover the invisible/programmatic case here.
-->

<rozie name="Captcha">

<props>
{
  // 'recaptcha' (Google reCAPTCHA v2) | 'hcaptcha' | 'turnstile' (Cloudflare)
  // | 'friendly' (Friendly Captcha).
  provider: {
    type: String,
    default: 'recaptcha',
    docs: {
      description:
        'Which widget to render: `recaptcha` (Google reCAPTCHA v2), `hcaptcha`, `turnstile` (Cloudflare), or `friendly` (Friendly Captcha). The first three share a near-identical explicit-render API; Friendly Captcha rides an internal `adapt()` bridge onto the same surface. Construction-time ‚Äî re-key the component to switch it live.',
    },
  },

  // The public site key from your provider dashboard. Required.
  sitekey:  {
    type: String,
    required: true,
    docs: {
      description:
        'Required. The public site key from your provider dashboard. Identifies your site to the chosen provider.',
    },
  },

  // The verified response token. Two-way: written by the widget on success,
  // cleared on expire/reset. Read it for form submission via r-model="token".
  token:    {
    type: String,
    default: '',
    model: true,
    docs: {
      description:
        'The verified response token (two-way `r-model`). As the sole `model: true` prop it drives the Angular `ControlValueAccessor`. Written by the widget on success and cleared on expire/reset, so reading it gives you the live response to send to your server for form submission.',
      example: '<Captcha r-model:token="token" provider="recaptcha" sitekey="‚Ä¶" />',
    },
  },

  // 'light' | 'dark' (all three) | 'auto' (Turnstile only). Construction-time.
  theme:    {
    type: String,
    default: 'light',
    docs: {
      description:
        'Widget color theme: `light` or `dark` (all three core providers), or `auto` (Turnstile only). Construction-time ‚Äî re-key the component to change it live.',
    },
  },

  // reCAPTCHA/hCaptcha: 'normal' | 'compact' | 'invisible'.
  // Turnstile: 'normal' | 'compact' | 'flexible'. Construction-time.
  // No-op for Friendly Captcha (FC has no `size` concept ‚Äî its `startMode`
  // analog rides through the `options` escape hatch instead).
  size:     {
    type: String,
    default: 'normal',
    docs: {
      description:
        'Widget size. reCAPTCHA/hCaptcha accept `normal`/`compact`/`invisible`; Turnstile accepts `normal`/`compact`/`flexible`. A no-op for Friendly Captcha (its `startMode` analog rides through the `options` escape hatch instead). Construction-time.',
    },
  },

  // Optional tabindex forwarded to the widget (omitted when null).
  tabindex: {
    type: Number,
    default: null,
    docs: {
      description:
        'Optional tab index forwarded to the rendered widget. Omitted from the render config when left unset (`null`).',
    },
  },

  // Escape hatch ‚Äî provider-specific render options merged last (e.g. Turnstile
  // `action`/`cData`/`retry`, hCaptcha `hl`, reCAPTCHA `badge`). Lets consumers
  // reach keys this component does not promote to first-class props.
  options:  {
    type: Object,
    default: () => ({}),
    docs: {
      description:
        'Escape hatch ‚Äî provider-specific render options merged last (e.g. Turnstile `action`/`cData`/`retry`, hCaptcha `hl`, reCAPTCHA `badge`, Friendly Captcha `startMode`). Lets you reach keys this component does not promote to first-class props.',
    },
  },
}
</props>

<script>
// The provider api.js loader (inject-once singleton + poll/timeout/error) lives
// in a vendored internal module so its branchy logic is unit-tested independent
// of any framework (see internal/loadCaptchaApi.test.ts). codegen copies
// src/internal/ into every leaf, so this relative import resolves verbatim √ó6.
import { loadCaptchaApi } from './internal/loadCaptchaApi'

// Live widget handle. Top-level lets ‚Üí React hoists to useRef (setup-once).
// `disposed` MUST be top-level (not declared inside $onMount): the Solid emitter
// extracts the teardown into a separate onCleanup() whose scope can't see a
// mount-body local, so a `let disposed` inside $onMount is out of scope in the
// teardown (TS2304). Top-level ‚Äî like api/widgetId ‚Äî is visible to both.
let api = null
let widgetId = null
let disposed = false

// The render config shared across all three providers. The hyphenated
// `expired-callback` / `error-callback` keys are the common option names each
// provider's render() accepts. `tabindex` is omitted unless set; `options`
// (the escape hatch) is merged last so a consumer can override any key.
const buildConfig = () => ({
  sitekey: $props.sitekey,
  theme: $props.theme,
  size: $props.size,
  ...($props.tabindex != null ? { tabindex: $props.tabindex } : {}),
  // NB: the param must NOT be named `token` ‚Äî on Vue, $model.token lowers to a
  // `defineModel('token')` ref named `token`, and a same-named param shadows it
  // (`token.value = token` would write the param, not the model ‚Üí v-model:token
  // never populates). Vue-only footgun (React/Solid lower to a setToken call).
  callback: (response) => {
    $model.token = response
    $emit('verify', { token: response, provider: $props.provider })
  },
  'expired-callback': () => {
    $model.token = ''
    $emit('expire', { provider: $props.provider })
  },
  'error-callback': () => {
    $model.token = ''
    $emit('error', { provider: $props.provider })
  },
  ...$props.options,
})

$onMount(() => {
  disposed = false
  loadCaptchaApi($props.provider)
    .then((a) => {
      if (disposed) return
      api = a
      widgetId = api.render($refs.widgetEl, buildConfig())
    })
    .catch((err) => {
      $emit('error', { provider: $props.provider, error: err })
    })
  return () => {
    disposed = true
    if (widgetId == null || !api) return
    // Turnstile fully removes a widget; reCAPTCHA/hCaptcha only reset.
    if (typeof api.remove === 'function') api.remove(widgetId)
    else if (typeof api.reset === 'function') api.reset(widgetId)
  }
})

// Imperative handle. Each guards on a live widget (null before render / after
// teardown). reset clears the two-way token to match the cleared widget.
function reset() {
  if (widgetId != null && api && typeof api.reset === 'function') api.reset(widgetId)
  $model.token = ''
}
// Invisible / programmatic challenge (size="invisible"). No-op until rendered.
function execute() {
  if (widgetId != null && api && typeof api.execute === 'function') api.execute(widgetId)
}
// Read the current response token on demand (e.g. just before form submit).
function getResponse() {
  return (widgetId != null && api && typeof api.getResponse === 'function') ? api.getResponse(widgetId) : ''
}

$expose({ reset, execute, getResponse })
</script>

<template>
<div ref="widgetEl" class="rozie-captcha"></div>
</template>

</rozie>
