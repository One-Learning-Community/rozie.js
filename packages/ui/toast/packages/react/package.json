{
  "name": "@rozie-ui/toast-react",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic React headless, accessible toast / notification host (queue, auto-dismiss, hover-pause, positioning, imperative show/dismiss/clear handle) — one accessible Rozie source compiled to React.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "toast",
    "toaster",
    "notification",
    "snackbar",
    "headless",
    "accessibility",
    "aria",
    "component",
    "react"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/toast/packages/react"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/Toaster.tsx",
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2 || ^19",
    "react-dom": "^18.2 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
