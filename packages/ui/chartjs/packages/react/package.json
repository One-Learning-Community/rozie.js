{
  "name": "@rozie-ui/chartjs-react",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic React chart component — one Rozie source compiled to React wrapping Chart.js.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "chartjs",
    "chart",
    "charts",
    "data-visualization",
    "component",
    "react"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/chartjs/packages/react"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./auto": {
      "types": "./dist/auto.d.mts",
      "import": "./dist/auto.mjs",
      "require": "./dist/auto.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "react": "^18.2 || ^19",
    "react-dom": "^18.2 || ^19",
    "chart.js": "^4"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "chart.js": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
