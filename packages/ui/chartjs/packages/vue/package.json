{
  "name": "@rozie-ui/chartjs-vue",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue chart component — one Rozie source compiled to Vue wrapping Chart.js.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "chartjs",
    "chart",
    "charts",
    "data-visualization",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/chartjs/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./auto": {
      "import": "./src/auto.ts",
      "types": "./src/auto.ts",
      "default": "./src/auto.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "chart.js": "^4"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "chart.js": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "chart.js": "^4",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
