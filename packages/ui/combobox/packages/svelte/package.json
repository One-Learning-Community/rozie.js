{
  "name": "@rozie-ui/combobox-svelte",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte headless WAI-ARIA combobox / autocomplete (text input + popup listbox, client/async filtering, full keyboard navigation, aria-activedescendant) — one accessible Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "combobox",
    "autocomplete",
    "typeahead",
    "select",
    "headless",
    "accessibility",
    "aria",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/combobox/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/Combobox.svelte",
      "types": "./dist/Combobox.svelte.d.ts",
      "default": "./dist/Combobox.svelte"
    },
    "./themes/*": "./src/themes/*",
    "./source": {
      "svelte": "./src/Combobox.svelte",
      "default": "./src/Combobox.svelte"
    },
    "./rozie-manifest.json": "./rozie-manifest.json"
  },
  "files": [
    "dist",
    "src",
    "rozie-manifest.json"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "@tanstack/virtual-core": "^3"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@tanstack/virtual-core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
