{
  "name": "@rozie-ui/combobox-solid",
  "version": "0.4.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid headless WAI-ARIA combobox / autocomplete (text input + popup listbox, client/async filtering, full keyboard navigation, aria-activedescendant) — one accessible Rozie source compiled to Solid.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "combobox",
    "autocomplete",
    "typeahead",
    "select",
    "headless",
    "accessibility",
    "aria",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/combobox/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/Combobox.tsx",
    "./themes/*": "./src/themes/*",
    "./rozie-manifest.json": "./rozie-manifest.json"
  },
  "files": [
    "dist",
    "src",
    "rozie-manifest.json"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*",
    "@solid-primitives/keyed": "^1.5.3"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "@tanstack/virtual-core": "^3"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "@tanstack/virtual-core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
