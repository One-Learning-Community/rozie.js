{
  // strictNullChecks/exactOptionalPropertyTypes/noImplicitAny relaxed: the
  // emitted Solid output is bundler-built (tsdown/oxc), not strict-tsc-authored.
  // This gate typechecks generated code, so it opts out of the author-strictness
  // flags the codegen does not satisfy while keeping the rest of strict mode.
  //
  // No `paths` alias for the embla packages: the published embla-carousel /
  // embla-carousel-autoplay packages ship real types.
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "noImplicitOverride": false,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
