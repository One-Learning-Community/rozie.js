{
  "name": "@rozie-ui/embla-solid",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid carousel wrapping Embla Carousel — one Rozie source compiled to Solid.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "embla",
    "embla-carousel",
    "carousel",
    "slider",
    "slideshow",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/embla/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*",
    "@solid-primitives/keyed": "^1.5.3"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "embla-carousel": "^8.6",
    "embla-carousel-autoplay": "^8.6"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "embla-carousel": {
      "optional": false
    },
    "embla-carousel-autoplay": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
