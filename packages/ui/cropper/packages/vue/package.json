{
  "name": "@rozie-ui/cropper-vue",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue image cropper wrapping Cropper.js — one Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "cropperjs",
    "cropper",
    "image",
    "crop",
    "image-cropper",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/cropper/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/Cropper.vue",
      "default": "./src/Cropper.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "cropperjs": "^1"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "cropperjs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "cropperjs": "^1",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
