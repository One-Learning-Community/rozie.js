{
  "name": "@rozie-ui/maplibre-vue",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue map component wrapping MapLibre GL JS — one Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "maplibre",
    "maplibre-gl",
    "map",
    "maps",
    "gl",
    "webgl",
    "geospatial",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/maplibre/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/MapLibre.vue",
      "default": "./src/MapLibre.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "maplibre-gl": "^5"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "maplibre-gl": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "maplibre-gl": "^5",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
