{
  "name": "@rozie-ui/maplibre-react",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic React map component wrapping MapLibre GL JS — one Rozie source compiled to React.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "maplibre",
    "maplibre-gl",
    "map",
    "maps",
    "gl",
    "webgl",
    "geospatial",
    "component",
    "react"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/maplibre/packages/react"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-react": "workspace:*"
  },
  "peerDependencies": {
    "react": "^18.2 || ^19",
    "react-dom": "^18.2 || ^19",
    "maplibre-gl": "^5"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": false
    },
    "react-dom": {
      "optional": false
    },
    "maplibre-gl": {
      "optional": false
    }
  },
  "devDependencies": {
    "@types/react": "^18",
    "@types/react-dom": "^18"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "*.css",
    "**/*.css"
  ]
}
