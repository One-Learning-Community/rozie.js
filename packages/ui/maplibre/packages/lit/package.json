{
  "name": "@rozie-ui/maplibre-lit",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit map component wrapping MapLibre GL JS — one Rozie source compiled to Lit.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "maplibre",
    "maplibre-gl",
    "map",
    "maps",
    "gl",
    "webgl",
    "geospatial",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/maplibre/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3",
    "@lit/context": "^1.1.6",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "maplibre-gl": "^5"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit/context": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "maplibre-gl": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": [
    "./dist/index.mjs",
    "./dist/index.cjs"
  ]
}
