{
  "name": "@rozie-ui/listbox-angular",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Angular headless WAI-ARIA listbox / combobox (single + multi-select, type-ahead, keyboard nav) — one accessible Rozie source compiled to Angular.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "listbox",
    "combobox",
    "select",
    "dropdown",
    "headless",
    "accessibility",
    "aria",
    "component",
    "angular"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/listbox/packages/angular"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/rozie-ui-listbox-angular.mjs"
    },
    "./themes/*": "./src/themes/*",
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@angular/core": "^19",
    "@angular/common": "^19",
    "@angular/forms": "^19"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    },
    "@angular/common": {
      "optional": false
    },
    "@angular/forms": {
      "optional": false
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "typecheck": "echo 'source+dist; ng-packagr declaration emit at build'"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/fesm2022/rozie-ui-listbox-angular.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/forms": "^19",
    "ng-packagr": "^19",
    "typescript": "~5.6.0"
  }
}
