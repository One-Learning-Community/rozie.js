{
  "name": "@rozie-ui/codemirror-angular",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Angular code editor — one Rozie source compiled to Angular wrapping CodeMirror 6.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "codemirror",
    "editor",
    "code-editor",
    "component",
    "angular"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/codemirror/packages/angular"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/rozie-ui-codemirror-angular.mjs"
    },
    "./languages": {
      "types": "./src/languages.ts",
      "default": "./src/languages.ts"
    },
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
