{
  "name": "@rozie-ui/codemirror-lit",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit code editor — one Rozie source compiled to Lit wrapping CodeMirror 6.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "codemirror",
    "editor",
    "code-editor",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/codemirror/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.2",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6",
    "@codemirror/commands": "^6",
    "@codemirror/lang-javascript": "^6",
    "@codemirror/theme-one-dark": "^6",
    "codemirror": "^6"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "@codemirror/state": {
      "optional": false
    },
    "@codemirror/view": {
      "optional": false
    },
    "@codemirror/commands": {
      "optional": false
    },
    "@codemirror/lang-javascript": {
      "optional": false
    },
    "@codemirror/theme-one-dark": {
      "optional": false
    },
    "codemirror": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
