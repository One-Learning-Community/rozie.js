{
  "name": "@rozie-ui/codemirror-svelte",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte code editor — one Rozie source compiled to Svelte wrapping CodeMirror 6.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "codemirror",
    "editor",
    "code-editor",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/codemirror/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/CodeMirror.svelte",
      "types": "./dist/CodeMirror.svelte.d.ts",
      "default": "./dist/CodeMirror.svelte"
    },
    "./languages": {
      "types": "./src/languages.ts",
      "import": "./src/languages.ts",
      "default": "./src/languages.ts"
    },
    "./source": {
      "svelte": "./src/CodeMirror.svelte",
      "default": "./src/CodeMirror.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "@codemirror/state": "^6",
    "@codemirror/view": "^6",
    "@codemirror/commands": "^6",
    "@codemirror/lang-javascript": "^6",
    "@codemirror/lang-html": "^6",
    "@codemirror/lang-css": "^6",
    "@codemirror/lang-sass": "^6",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-json": "^6",
    "@codemirror/lang-markdown": "^6",
    "@codemirror/lang-yaml": "^6",
    "@codemirror/lang-xml": "^6",
    "@codemirror/lang-python": "^6",
    "@codemirror/lang-sql": "^6",
    "@codemirror/theme-one-dark": "^6",
    "codemirror": "^6"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@codemirror/state": {
      "optional": false
    },
    "@codemirror/view": {
      "optional": false
    },
    "@codemirror/commands": {
      "optional": false
    },
    "@codemirror/lang-javascript": {
      "optional": false
    },
    "@codemirror/theme-one-dark": {
      "optional": false
    },
    "codemirror": {
      "optional": false
    },
    "@codemirror/lang-html": {
      "optional": false
    },
    "@codemirror/lang-css": {
      "optional": false
    },
    "@codemirror/lang-sass": {
      "optional": false
    },
    "@codemirror/lang-vue": {
      "optional": false
    },
    "@codemirror/lang-json": {
      "optional": false
    },
    "@codemirror/lang-markdown": {
      "optional": false
    },
    "@codemirror/lang-yaml": {
      "optional": false
    },
    "@codemirror/lang-xml": {
      "optional": false
    },
    "@codemirror/lang-python": {
      "optional": false
    },
    "@codemirror/lang-sql": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
