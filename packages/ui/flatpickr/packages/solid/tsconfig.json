{
  // strictNullChecks/exactOptionalPropertyTypes/noImplicitAny relaxed: the
  // emitted Solid output is bundler-built (tsdown/oxc), not strict-tsc-authored.
  // Emitted DOM refs (typed string|null) and generated IIFE defaults are
  // proven-correct via dist-parity but are not author-strictness-clean. This
  // gate typechecks generated code, so it opts out of the author-strictness
  // flags the codegen does not satisfy while keeping the rest of strict mode.
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    // Gate-only loose flatpickr stub — see ../../types/flatpickr.d.ts. The emit
    // is runtime-correct; flatpickr's published option-literal unions are
    // stricter than the string props the generated call passes through.
    "baseUrl": ".",
    "paths": {
      "flatpickr": ["../../types/flatpickr.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
