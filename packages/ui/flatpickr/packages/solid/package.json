{
  "name": "@rozie-ui/flatpickr-solid",
  "version": "0.1.3",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid date/time picker — one Rozie source compiled to Solid wrapping flatpickr.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "flatpickr",
    "datepicker",
    "date-picker",
    "calendar",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/flatpickr/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "flatpickr": "^4.6"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "flatpickr": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
