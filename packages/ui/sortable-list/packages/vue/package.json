{
  "name": "@rozie-ui/sortable-list-vue",
  "version": "0.1.3",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue drag-and-drop sortable list — one Rozie source compiled to Vue via SortableJS.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "sortable",
    "drag-and-drop",
    "sortablejs",
    "list",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/sortable-list/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/SortableList.vue",
      "default": "./src/SortableList.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "sortablejs": "^1.15"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "sortablejs": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/sortablejs": "^1.15",
    "@vitejs/plugin-vue": "^6",
    "sortablejs": "^1.15",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
