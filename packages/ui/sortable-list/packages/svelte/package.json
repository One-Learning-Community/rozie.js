{
  "name": "@rozie-ui/sortable-list-svelte",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte drag-and-drop sortable list — one Rozie source compiled to Svelte via SortableJS.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "sortable",
    "drag-and-drop",
    "sortablejs",
    "list",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/sortable-list/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/SortableList.svelte",
      "types": "./dist/SortableList.svelte.d.ts",
      "default": "./dist/SortableList.svelte"
    },
    "./source": {
      "svelte": "./src/SortableList.svelte",
      "default": "./src/SortableList.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "sortablejs": "^1.15"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "sortablejs": {
      "optional": false
    }
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  }
}
