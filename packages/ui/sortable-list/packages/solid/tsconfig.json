{
  // exactOptionalPropertyTypes/noImplicitAny relaxed: the emitted Solid
  // output is bundler-built (tsdown/oxc), not strict-tsc-authored. This gate
  // typechecks generated code, so it opts out of the author-strictness flags
  // the codegen does not satisfy while keeping the rest of strict mode.
  // strictNullChecks: true (260712-ig6) — the last residual (null-widened
  // props spliced into the SortableJS options object literal — group,
  // handle, ghostClass, chosenClass, dragClass, filter, easing —
  // TS2345/TS2322) is now closed at the emitter (Solid rewriteScript's
  // isNullWidenedPropObjectLiteralCallArgTarget `?? undefined` splice-site
  // coercion); this leaf typechecks clean under strictNullChecks.
  "extends": "../../../../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "skipLibCheck": true,
    "strictNullChecks": true,
    "exactOptionalPropertyTypes": false,
    "noImplicitAny": false,
    "lib": ["ES2022", "DOM", "DOM.Iterable"]
  },
  "include": ["src"],
  "exclude": ["dist", "node_modules"]
}
