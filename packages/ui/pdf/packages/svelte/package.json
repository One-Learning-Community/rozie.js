{
  "name": "@rozie-ui/pdf-svelte",
  "version": "0.2.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte PDF viewer wrapping PDF.js — one Rozie source compiled to Svelte.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "pdf",
    "pdfjs",
    "pdf-viewer",
    "pdf-js",
    "viewer",
    "document",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/pdf/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/PdfViewer.svelte",
      "types": "./dist/PdfViewer.svelte.d.ts",
      "default": "./dist/PdfViewer.svelte"
    },
    "./source": {
      "svelte": "./src/PdfViewer.svelte",
      "default": "./src/PdfViewer.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "pdfjs-dist": "^6"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "pdfjs-dist": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
