{
  "name": "@rozie-ui/pdf-vue",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue PDF viewer wrapping PDF.js — one Rozie source compiled to Vue.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "pdf",
    "pdfjs",
    "pdf-viewer",
    "pdf-js",
    "viewer",
    "document",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/pdf/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/PdfViewer.vue",
      "default": "./src/PdfViewer.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "pdfjs-dist": "^6"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "pdfjs-dist": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@vitejs/plugin-vue": "^6",
    "pdfjs-dist": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
