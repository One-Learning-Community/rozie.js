{
  "name": "@rozie-ui/fullcalendar-vue",
  "version": "0.1.1",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Vue calendar/scheduler — one Rozie source compiled to Vue wrapping FullCalendar.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "fullcalendar",
    "calendar",
    "scheduler",
    "events",
    "component",
    "vue"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/fullcalendar/packages/vue"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./source": {
      "vue": "./src/FullCalendar.vue",
      "default": "./src/FullCalendar.vue"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "vue": "^3.4",
    "@fullcalendar/core": "^6.1",
    "@fullcalendar/daygrid": "^6.1",
    "@fullcalendar/timegrid": "^6.1",
    "@fullcalendar/interaction": "^6.1"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": false
    },
    "@fullcalendar/core": {
      "optional": false
    },
    "@fullcalendar/daygrid": {
      "optional": false
    },
    "@fullcalendar/timegrid": {
      "optional": false
    },
    "@fullcalendar/interaction": {
      "optional": false
    }
  },
  "scripts": {
    "build": "vite build && vue-tsc --declaration --emitDeclarationOnly",
    "typecheck": "vue-tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "devDependencies": {
    "@fullcalendar/core": "^6.1",
    "@fullcalendar/daygrid": "^6.1",
    "@fullcalendar/interaction": "^6.1",
    "@fullcalendar/timegrid": "^6.1",
    "@vitejs/plugin-vue": "^6",
    "vite": "^8",
    "vite-plugin-css-injected-by-js": "^5",
    "vue": "^3.5",
    "vue-tsc": "^3"
  }
}
