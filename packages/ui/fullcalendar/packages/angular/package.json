{
  "name": "@rozie-ui/fullcalendar-angular",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Angular calendar/scheduler — one Rozie source compiled to Angular wrapping FullCalendar.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "fullcalendar",
    "calendar",
    "scheduler",
    "events",
    "component",
    "angular"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/fullcalendar/packages/angular"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/rozie-ui-fullcalendar-angular.mjs"
    },
    "./source": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "peerDependencies": {
    "@angular/core": "^19",
    "@angular/common": "^19",
    "@fullcalendar/core": "^6.1",
    "@fullcalendar/daygrid": "^6.1",
    "@fullcalendar/timegrid": "^6.1",
    "@fullcalendar/interaction": "^6.1"
  },
  "peerDependenciesMeta": {
    "@angular/core": {
      "optional": false
    },
    "@angular/common": {
      "optional": false
    },
    "@fullcalendar/core": {
      "optional": false
    },
    "@fullcalendar/daygrid": {
      "optional": false
    },
    "@fullcalendar/timegrid": {
      "optional": false
    },
    "@fullcalendar/interaction": {
      "optional": false
    }
  },
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "typecheck": "echo 'source+dist; ng-packagr declaration emit at build'"
  },
  "publishConfig": {
    "access": "public"
  },
  "module": "./dist/fesm2022/rozie-ui-fullcalendar-angular.mjs",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "tslib": "^2"
  },
  "devDependencies": {
    "@angular/common": "^19",
    "@angular/compiler": "^19",
    "@angular/compiler-cli": "^19",
    "@angular/core": "^19",
    "@angular/forms": "^19",
    "ng-packagr": "^19",
    "typescript": "~5.6.0"
  }
}
