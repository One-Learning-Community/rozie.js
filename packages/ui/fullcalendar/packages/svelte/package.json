{
  "name": "@rozie-ui/fullcalendar-svelte",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Svelte calendar/scheduler — one Rozie source compiled to Svelte wrapping FullCalendar.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "fullcalendar",
    "calendar",
    "scheduler",
    "events",
    "component",
    "svelte"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/fullcalendar/packages/svelte"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "exports": {
    ".": {
      "svelte": "./dist/FullCalendar.svelte",
      "types": "./dist/FullCalendar.svelte.d.ts",
      "default": "./dist/FullCalendar.svelte"
    },
    "./source": {
      "svelte": "./src/FullCalendar.svelte",
      "default": "./src/FullCalendar.svelte"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-svelte": "workspace:^"
  },
  "peerDependencies": {
    "svelte": "^5",
    "@fullcalendar/core": "^6.1",
    "@fullcalendar/daygrid": "^6.1",
    "@fullcalendar/timegrid": "^6.1",
    "@fullcalendar/interaction": "^6.1"
  },
  "peerDependenciesMeta": {
    "svelte": {
      "optional": false
    },
    "@fullcalendar/core": {
      "optional": false
    },
    "@fullcalendar/daygrid": {
      "optional": false
    },
    "@fullcalendar/timegrid": {
      "optional": false
    },
    "@fullcalendar/interaction": {
      "optional": false
    }
  },
  "scripts": {
    "build": "svelte-package --input src --output dist",
    "typecheck": "echo 'source+dist; svelte-check at repo level'"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@sveltejs/package": "^2",
    "@sveltejs/vite-plugin-svelte": "^5",
    "svelte": "^5",
    "svelte2tsx": "^0.7",
    "typescript": "~5.6.0"
  }
}
