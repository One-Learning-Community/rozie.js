{
  "name": "@rozie-ui/fullcalendar-lit",
  "version": "0.1.2",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Lit calendar/scheduler — one Rozie source compiled to Lit wrapping FullCalendar.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "fullcalendar",
    "calendar",
    "scheduler",
    "events",
    "component",
    "lit"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/fullcalendar/packages/lit"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-lit": "workspace:*"
  },
  "peerDependencies": {
    "lit": "^3.2",
    "@lit-labs/preact-signals": "^1.0.0",
    "@preact/signals-core": "^1.3.0",
    "@fullcalendar/core": "^6.1",
    "@fullcalendar/daygrid": "^6.1",
    "@fullcalendar/timegrid": "^6.1",
    "@fullcalendar/interaction": "^6.1"
  },
  "peerDependenciesMeta": {
    "lit": {
      "optional": false
    },
    "@lit-labs/preact-signals": {
      "optional": false
    },
    "@preact/signals-core": {
      "optional": false
    },
    "@fullcalendar/core": {
      "optional": false
    },
    "@fullcalendar/daygrid": {
      "optional": false
    },
    "@fullcalendar/timegrid": {
      "optional": false
    },
    "@fullcalendar/interaction": {
      "optional": false
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
