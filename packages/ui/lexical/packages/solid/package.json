{
  "name": "@rozie-ui/lexical-solid",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "license": "MIT",
  "description": "Idiomatic Solid cross-framework Lexical rich-text editor — editor shell, RichText/History/List/Link plugins, selection-reading toolbar, and an @mention DecoratorNode — one Rozie source compiled to Solid wrapping Meta's Lexical.",
  "keywords": [
    "rozie",
    "rozie-ui",
    "lexical",
    "editor",
    "rich-text-editor",
    "wysiwyg",
    "contenteditable",
    "mention",
    "component",
    "solid"
  ],
  "author": "One Learning Community (https://github.com/One-Learning-Community)",
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/ui/lexical/packages/solid"
  },
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./source": "./src/LexicalEditor.tsx"
  },
  "files": [
    "dist",
    "src"
  ],
  "dependencies": {
    "@rozie/runtime-solid": "workspace:*"
  },
  "peerDependencies": {
    "solid-js": "^1.8",
    "lexical": "^0.48.0",
    "@lexical/rich-text": "^0.48.0",
    "@lexical/history": "^0.48.0",
    "@lexical/list": "^0.48.0",
    "@lexical/link": "^0.48.0",
    "@lexical/utils": "^0.48.0"
  },
  "peerDependenciesMeta": {
    "solid-js": {
      "optional": false
    },
    "lexical": {
      "optional": false
    },
    "@lexical/rich-text": {
      "optional": false
    },
    "@lexical/utils": {
      "optional": false
    },
    "@lexical/history": {
      "optional": true
    },
    "@lexical/list": {
      "optional": true
    },
    "@lexical/link": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rozie-ui/lexical": "workspace:*"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  }
}
