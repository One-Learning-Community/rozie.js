<rozie name="D20Listeners" inherit-attrs="false" inherit-listeners="false">
<props>{ closeOnOutsideClick: { type: Boolean, default: true } }</props>
<script>
const noop = () => {}
</script>
<listeners>
  <listener :target="document" @click.outside($refs.a,$refs.b).stop="noop" r-if="true" />
</listeners>
<template>
  <div ref="a"></div>
  <div ref="b"></div>
</template>
</rozie>
