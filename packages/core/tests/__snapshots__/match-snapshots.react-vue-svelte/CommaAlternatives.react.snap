import { useState } from 'react';
import './CommaAlternatives.css';

interface CommaAlternativesProps {}

export default function CommaAlternatives(props: CommaAlternativesProps): JSX.Element {
  const attrs = props as Record<string, unknown>;
  const [bound, setBound] = useState('max');

  return (
    <>
    {(bound === 'max' || bound === 'min') ? <span className={"extremum"} data-rozie-s-65af5512="">at an extremum</span> : (bound === 'mid') ? <span className={"middle"} data-rozie-s-65af5512="">in the middle</span> : <span className={"other"} data-rozie-s-65af5512="">somewhere else</span>}
    </>
  );
}
