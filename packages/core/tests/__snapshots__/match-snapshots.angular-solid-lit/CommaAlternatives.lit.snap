import { LitElement, css, html } from 'lit';
import { customElement } from 'lit/decorators.js';
import { SignalWatcher, signal } from '@lit-labs/preact-signals';

@customElement('rozie-comma-alternatives')
export default class CommaAlternatives extends SignalWatcher(LitElement) {
  static styles = css`
.extremum[data-rozie-s-65af5512] { font-weight: 600; }
.middle[data-rozie-s-65af5512] { opacity: 0.8; }
.other[data-rozie-s-65af5512] { opacity: 0.5; }
`;

  private _bound = signal('max');

  private _disconnectCleanups: Array<() => void> = [];
  // Re-parenting guard: set true once the deferred teardown has actually
  // run (a genuine un-mount), so a subsequent reconnect knows to re-arm.
  private _rozieTornDown = false;

  disconnectedCallback(): void {
    super.disconnectedCallback();
    queueMicrotask(() => {
      if (this.isConnected || this._rozieTornDown) return;
      this._rozieTornDown = true;
      for (const fn of this._disconnectCleanups) fn();
      this._disconnectCleanups = [];
    });
  }

  render() {
    return html`
${this._bound.value === 'max' || this._bound.value === 'min' ? html`<span class="extremum" data-rozie-s-65af5512>at an extremum</span>` : this._bound.value === 'mid' ? html`<span class="middle" data-rozie-s-65af5512>in the middle</span>` : html`<span class="other" data-rozie-s-65af5512>somewhere else</span>`}
`;
  }
}
