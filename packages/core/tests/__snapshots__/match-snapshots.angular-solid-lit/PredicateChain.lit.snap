import { LitElement, css, html } from 'lit';
import { customElement } from 'lit/decorators.js';
import { SignalWatcher, signal } from '@lit-labs/preact-signals';

@customElement('rozie-predicate-chain')
export default class PredicateChain extends SignalWatcher(LitElement) {
  static styles = css`
:host{display:contents}
.high[data-rozie-s-e116a46e] { font-weight: 700; }
.some[data-rozie-s-e116a46e] { opacity: 0.85; }
.none[data-rozie-s-e116a46e] { opacity: 0.5; }
`;

  private _count = signal(5);

  private _disconnectCleanups: Array<() => void> = [];
  // Re-parenting guard: set true once the deferred teardown has actually
  // run (a genuine un-mount), so a subsequent reconnect knows to re-arm.
  private _rozieTornDown = false;

  disconnectedCallback(): void {
    super.disconnectedCallback();
    queueMicrotask(() => {
      if (this.isConnected || this._rozieTornDown) return;
      this._rozieTornDown = true;
      for (const fn of this._disconnectCleanups) fn();
      this._disconnectCleanups = [];
    });
  }

  render() {
    return html`
${this._count.value > 10 ? html`<strong class="high" data-rozie-s-e116a46e>plenty</strong>` : this._count.value > 0 ? html`<span class="some" data-rozie-s-e116a46e>a few</span>` : html`<span class="none" data-rozie-s-e116a46e>none</span>`}
`;
  }
}
