<script lang="ts">
let score = $state(72);

const classify = () => score >= 50 ? 'pass' : 'fail';
const subClassify = () => score >= 90 ? 'distinction' : 'merit';

const __rozieMatch_0 = $derived(classify());

const __rozieMatch_1 = $derived(subClassify());
</script>


{#if __rozieMatch_0 === 'pass'}<template>
    <div class="passed">
      {#if __rozieMatch_1 === 'distinction'}<strong>passed with distinction</strong>{:else if __rozieMatch_1 === 'merit'}<span>passed with merit</span>{:else}<span>passed</span>{/if}
    </div>
  </template>{:else if __rozieMatch_0 === 'fail'}<span class="failed">did not pass</span>{:else}<span class="unknown">ungraded</span>{/if}


<style>
.passed { color: #15803d; }
.failed { color: #b91c1c; }
.unknown { opacity: 0.5; }
</style>
