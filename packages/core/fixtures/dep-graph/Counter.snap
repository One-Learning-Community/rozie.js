      "scope": "props",
      "path": [
        "value"
      ]
    },
    {
      "scope": "props",
      "path": [
        "step"
      ]
    },
    {
      "scope": "props",
      "path": [
        "max"
      ]
    }
  ],
  "template.attr./div-1/:class": [
    {
      "scope": "data",
      "path": [
        "hovering"
      ]
    }
  ],
  "template.attr./div-1/@mouseenter": [
    {
      "scope": "data",
      "path": [
        "hovering"
      ]
    }
  ],
  "template.attr./div-1/@mouseleave": [
    {
      "scope": "data",
      "path": [
        "hovering"
      ]
