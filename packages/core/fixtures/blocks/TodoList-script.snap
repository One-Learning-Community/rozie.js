                  "filename": "TodoList.rozie"
                }
              },
              {
                "type": "CommentLine",
                "value": " with `HTMLElement.prototype.remove()` on the Lit target — Lit emits user",
                "start": 1185,
                "end": 1260,
                "loc": {
                  "start": {
                    "line": 49,
                    "column": 0,
