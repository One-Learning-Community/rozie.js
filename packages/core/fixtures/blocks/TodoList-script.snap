                "type": "CommentLine",
                "value": " Internal method renamed from `remove` to `removeItem` to avoid colliding",
                "start": 1109,
                "end": 1184,
                "loc": {
                  "start": {
                    "line": 48,
                    "column": 0,
                    "index": 1109
                  },
