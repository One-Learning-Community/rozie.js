    "style": {
      "type": "StyleAST",
      "loc": {
        "start": 2478,
        "end": 2823
      },
      "cssText": "\n.todo-list { font-family: system-ui, sans-serif; }\nul { list-style: none; padding: 0; }\nli { display: flex; align-items: center; gap: 0.5rem; padding: 0.25rem 0; }\nli.done span { text-decoration: line-through; opacity: 0.5; }\n.empty { color: rgba(0, 0, 0, 0.4); font-style: italic; }\nform { display: flex; gap: 0.25rem; margin-block: 0.5rem; }\n",
      "rules": [
        {
          "selector": ".todo-list",
          "loc": {
            "start": 2479,
            "end": 2529
          },
          "isRootEscape": false
        },
