                    "column": 75,
                    "index": 1184
                  },
                  "filename": "TodoList.rozie"
                }
              },
              {
                "type": "CommentLine",
                "value": " with `HTMLElement.prototype.remove()` on the Lit target — Lit emits user",
                "start": 1185,
                "end": 1260,
                "loc": {
                  "start": {
                    "line": 49,
                    "column": 0,
                    "index": 1185
                  },
                  "end": {
                    "line": 49,
                    "column": 75,
                    "index": 1260
                  },
                  "filename": "TodoList.rozie"
                }
              },
              {
                "type": "CommentLine",
                "value": " methods as class fields and the resulting `remove(id)` signature is",
                "start": 1261,
                "end": 1331,
                "loc": {
                  "start": {
                    "line": 50,
                    "column": 0,
                    "index": 1261
                  },
                  "end": {
                    "line": 50,
                    "column": 70,
                    "index": 1331
                  },
                  "filename": "TodoList.rozie"
                }
              },
              {
                "type": "CommentLine",
                "value": " incompatible with the inherited `remove(): void`. Public API is unchanged:",
                "start": 1332,
                "end": 1409,
                "loc": {
                  "start": {
                    "line": 51,
                    "column": 0,
                    "index": 1332
                  },
                  "end": {
                    "line": 51,
                    "column": 77,
                    "index": 1409
                  },
                  "filename": "TodoList.rozie"
                }
              },
              {
                "type": "CommentLine",
                "value": " the slot param is still `:remove`, the emitted event is still `'remove'`.",
