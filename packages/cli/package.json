{
  "name": "@rozie/cli",
  "version": "0.1.1",
  "description": "Command-line interface for Rozie.js — compile .rozie files to React, Vue, Svelte, Angular, Solid, and Lit from the terminal.",
  "type": "module",
  "private": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "rozie": "./dist/bin.cjs"
  },
  "files": [
    "dist",
    "src",
    "!src/**/__tests__/**",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@babel/code-frame": "^7.29.0",
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.3",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@rozie/core": "workspace:*",
    "@rozie/runtime-lit": "workspace:*",
    "@rozie/runtime-react": "workspace:*",
    "@rozie/runtime-solid": "workspace:*",
    "@rozie/runtime-svelte": "workspace:*",
    "@rozie/runtime-vue": "workspace:*",
    "@vue/compiler-sfc": "^3.5.33",
    "chokidar": "^4.0.3",
    "commander": "^14.0.0",
    "fast-glob": "^3.3.3",
    "htmlparser2": "^12.0.0",
    "magic-string": "^0.30.21",
    "picocolors": "^1.1.0",
    "postcss": "^8.5.13",
    "prettier": "^3.8.3",
    "sass": "^1.97.3"
  },
  "peerDependencies": {
    "prettier-plugin-svelte": "^3.4.0"
  },
  "peerDependenciesMeta": {
    "prettier-plugin-svelte": {
      "optional": true
    }
  },
  "devDependencies": {
    "@rozie/target-angular": "workspace:*",
    "@rozie/target-lit": "workspace:*",
    "@rozie/target-react": "workspace:*",
    "@rozie/target-solid": "workspace:*",
    "@rozie/target-svelte": "workspace:*",
    "@rozie/target-vue": "workspace:*",
    "@rozie/unplugin": "workspace:*",
    "prettier-plugin-svelte": "^3.4.0",
    "vitest": "^4.1.5"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/One-Learning-Community/rozie.js.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/One-Learning-Community/rozie.js#readme",
  "bugs": {
    "url": "https://github.com/One-Learning-Community/rozie.js/issues"
  },
  "author": "One Learning Community (https://github.com/One-Learning-Community)"
}
