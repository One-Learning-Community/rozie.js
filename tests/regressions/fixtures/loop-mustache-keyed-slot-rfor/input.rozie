<rozie name="LoopMustacheKeyedSlotRfor">

<props>
{
  rows: { type: Array, default: () => [] },
}
</props>

<script lang="ts">
function noop(): void {}
</script>

<template>
<!--
  R11-1 KEYED variant: a <slot> inside a <template r-for :key>. The `:key`
  routes Solid through `<Key each={…} by={…}>{item => BODY}</Key>` (a
  DIFFERENT composition site than the keyless `<For>` used by the other four
  R11-1 fixtures — emitTemplateNode.ts:377 vs :351). Exercises the shared
  bodyJsx strip fix at BOTH Solid composition sites. See BUG-LEDGER.md#R11-1.
-->
<div class="r"><template r-for="row in $props.rows" :key="row.id"><slot :name="row" /></template></div>
</template>

</rozie>
