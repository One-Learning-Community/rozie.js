<rozie name="ConnectedRearm">

<data>
{
  pressed: 0,
}
</data>

<script>
const onKey = () => { $data.pressed += 1 }
</script>

<listeners>
{
  // D-SH-02 reproduction: the Lit emitter wired ALL listener setup into
  // firstUpdated() — which Lit runs exactly once. disconnectedCallback()
  // correctly drained _disconnectCleanups, but there was NO connectedCallback()
  // override to re-arm the listener after a disconnect → reconnect cycle, so a
  // reconnected element was left with zero listeners. The fix lifts listener
  // wiring into _armListeners(), called from firstUpdated() (first render) AND
  // connectedCallback() (every reconnect, guarded by this.hasUpdated).
  "document:keydown": {
    handler: onKey,
  },
}
</listeners>

<template>
<div class="rearm">{{ $data.pressed }}</div>
</template>

<style>
.rearm { font-variant-numeric: tabular-nums; }
</style>

</rozie>
