<rozie name="Counter">

<props>
{
  value: { type: Number, default: 0, model: true },
  step:  { type: Number, default: 1 },
}
</props>

<script>
const increment = () => { $props.value += $props.step }
</script>

<template>
<button @click="increment">{{ $props.value }}</button>
</template>

</rozie>
