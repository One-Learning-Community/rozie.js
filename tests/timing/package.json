{
  "name": "rozie-timing-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "//": "Internal cross-framework timing-parity tests. The Angular leg babel-transforms the emitted Angular source, evals it as an ESM module, and JIT-compiles via TestBed — exercises the runtime path that consumers using AOT will not hit, but verifies the emitted source's structural shape and timing wraparound on the same axis as the other three targets.",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@rozie/core": "workspace:*",
    "@rozie/runtime-react": "workspace:*",
    "@rozie/runtime-vue": "workspace:*",
    "@rozie/target-angular": "workspace:*",
    "@rozie/target-react": "workspace:*",
    "@rozie/target-svelte": "workspace:*",
    "@rozie/target-vue": "workspace:*"
  },
  "devDependencies": {
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-browser-dynamic": "^21.0.0",
    "@babel/core": "^7.29",
    "@babel/plugin-proposal-decorators": "^7.29",
    "@babel/plugin-transform-class-properties": "^7.28",
    "@babel/preset-env": "^7.29",
    "@babel/preset-react": "^7.28",
    "@babel/preset-typescript": "^7.28",
    "@testing-library/react": "^16",
    "@types/babel__core": "^7.20.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vue/compiler-sfc": "^3.5.33",
    "@vue/test-utils": "^2.4.10",
    "happy-dom": "^15",
    "jsdom": "^25",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "rxjs": "^7.8",
    "svelte": "^5.0.0",
    "tslib": "^2.6",
    "typescript": "~5.9.3",
    "vitest": "^4.1.5",
    "vue": "^3.5.33",
    "zone.js": "~0.15.0"
  }
}
