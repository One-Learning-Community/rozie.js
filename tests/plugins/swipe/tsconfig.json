{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "noEmit": true,
    "module": "ESNext",
    "target": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "verbatimModuleSyntax": true,
    "types": ["vitest/globals", "node"]
  },
  "include": ["src/**/*", "vitest.config.ts"],
  "exclude": ["dist", "node_modules", "fixtures"]
}
