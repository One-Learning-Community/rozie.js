{
  "name": "rozie",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "biome format --write .",
    "playground": "pnpm --filter rozie-playground dev",
    "playground:rebuild": "turbo run build --filter=@rozie/core --force && pnpm --filter rozie-playground dev",
    "vr": "pnpm --filter @rozie/visual-regression test:visual",
    "vr:rebuild": "turbo run build --filter=@rozie/visual-regression --force && pnpm --filter @rozie/visual-regression test:visual",
    "vr-preview": "pnpm --filter @rozie/visual-regression preview",
    "vr-preview:build": "turbo run build --filter=@rozie/visual-regression --force && pnpm --filter @rozie/visual-regression preview",
    "vr:debug": "pnpm --filter=@rozie/visual-regression run build:debug",
    "prepush": "bash scripts/ci-prepush.sh",
    "install-hooks": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "turbo": "^2.9.7",
    "tsdown": "^0.21.10",
    "vitest": "^4.1.5",
    "typescript": "~5.6.0",
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.0.0"
  },
  "pnpm": {
    "packageExtensions": {
      "@analogjs/vite-plugin-angular": {
        "peerDependencies": {
          "typescript": ">=5.5",
          "@angular/compiler": "^17 || ^18 || ^19 || ^20 || ^21",
          "@angular/compiler-cli": "^17 || ^18 || ^19 || ^20 || ^21"
        }
      }
    }
  }
}
